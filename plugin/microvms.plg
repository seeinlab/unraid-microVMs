<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN>
<PLUGIN name="microvms" author="seein" version="2026.07.05.1"
  pluginURL="https://raw.githubusercontent.com/seein/unraid-microVMs/main/plugin/microvms.plg"
  launch="Settings/MicroVMsControlplane"
  min="6.12.0">

<CHANGES><![CDATA[
### 2026.07.05.1
- Plugin renamed: microvms
- Settings: microVMs Controlplane
- Engine renamed to VMM (Cloud Hypervisor, Firecracker)
- Infra-as-code config: cloud-hypervisor.json / firecracker.json
- Devmapper thin pool for space-efficient rootfs
- Liquidmetal section: enable/disable flintlockd + containerd + crane registry
- Logs consolidated to /var/log/microvms/ (like libvirt)
- microvms-containerd (separate from Docker's containerd)
- All paths restructured under /mnt/user/system/microvms/
]]></CHANGES>

<!-- PRE-INSTALL: Stop existing service -->
<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
/etc/rc.d/rc.microvms stop 2>/dev/null
# Create tmp directory for tarball extraction
mkdir -p /boot/config/plugins/microvms/tmp
]]>
</INLINE>
</FILE>

<!-- ============================================================ -->
<!-- DIRECT BINARY DOWNLOADS                                       -->
<!-- ============================================================ -->

