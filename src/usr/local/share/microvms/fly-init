#!/bin/sh
# /fly/init — Generic microVM init (reads /fly/run.json)
# Injected by microvms plugin. Same binary for ALL VMs.
# Only /fly/run.json differs per VM.

# 1. Mount virtual filesystems
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev 2>/dev/null
mkdir -p /dev/pts && mount -t devpts devpts /dev/pts
# /dev/fd needed by postgres initdb and other tools
ln -sf /proc/self/fd /dev/fd 2>/dev/null
ln -sf /proc/self/fd/0 /dev/stdin 2>/dev/null
ln -sf /proc/self/fd/1 /dev/stdout 2>/dev/null
ln -sf /proc/self/fd/2 /dev/stderr 2>/dev/null

# 2. Read /fly/run.json
CONFIG="/fly/run.json"
if [ ! -f "$CONFIG" ]; then
  echo "FATAL: /fly/run.json not found"
  sleep 5
  poweroff -f 2>/dev/null
  exit 1
fi

# Simple JSON field extractor (no jq needed, handles multi-line pretty-printed JSON)
json_val() {
  sed -n 's/.*"'"$1"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$CONFIG" | head -1
}
json_bool() {
  sed -n 's/.*"'"$1"'"[[:space:]]*:[[:space:]]*\([a-z]*\).*/\1/p' "$CONFIG" | head -1
}
json_array() {
  # Extract array content between [ and ], strip quotes and whitespace
  sed -n '/"'"$1"'".*\[/,/\]/p' "$CONFIG" | grep -v "\"$1\"" | sed 's/[][]//g;s/"//g;s/,//g' | tr -s ' \n' ' ' | sed 's/^ *//;s/ *$//'
}

# 3. Set hostname
HOSTNAME=$(json_val hostname)
[ -n "$HOSTNAME" ] && hostname "$HOSTNAME" 2>/dev/null

# 4. Network: configured by kernel ip= parameter (works without iproute2)
# DNS only (kernel doesn't handle this)
DNS=$(json_array dns)
: > /etc/resolv.conf 2>/dev/null
for ns in $DNS; do
  echo "nameserver $ns" >> /etc/resolv.conf
done
[ ! -s /etc/resolv.conf ] && echo "nameserver 8.8.8.8" > /etc/resolv.conf

# 4b. Mount virtiofs shares (from /fly/mounts: tab-separated tag\tguest_path)
if [ -f /fly/mounts ]; then
  while IFS=$(printf '\t') read -r tag guest_path; do
    [ -n "$tag" ] && [ -n "$guest_path" ] && {
      mkdir -p "$guest_path"
      mount -t virtiofs "$tag" "$guest_path" 2>/dev/null && echo "Mounted virtiofs: $tag -> $guest_path"
    }
  done < /fly/mounts
fi

# 5. Set environment
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export HOME=/root
export TERM=dumb
export COLUMNS=200
export LINES=50
# Source user-defined env vars (Fly.io pattern)
[ -f /fly/env.sh ] && . /fly/env.sh

# 6. Build exec command from entrypoint + cmd
# Generate /fly/run.sh with properly quoted args
RUNCMD="/fly/run.sh"
echo '#!/bin/sh' > "$RUNCMD"
printf 'exec' >> "$RUNCMD"
# Extract entrypoint args
sed -n '/"entrypoint".*\[/,/\]/p' "$CONFIG" | grep -v '"entrypoint"' | grep -v '[][]' | sed 's/,//g;s/^[[:space:]]*//' | while IFS= read -r line; do
  arg=$(echo "$line" | sed 's/^"//;s/"$//')
  [ -n "$arg" ] && printf ' "%s"' "$arg" >> "$RUNCMD"
done
# Extract cmd args
sed -n '/"cmd".*\[/,/\]/p' "$CONFIG" | grep -v '"cmd"' | grep -v '[][]' | sed 's/,//g;s/^[[:space:]]*//' | while IFS= read -r line; do
  arg=$(echo "$line" | sed 's/^"//;s/"$//')
  [ -n "$arg" ] && printf ' "%s"' "$arg" >> "$RUNCMD"
done
echo "" >> "$RUNCMD"
chmod 755 "$RUNCMD"

# 7. Console mode
CONSOLE=$(json_bool console)
SHELL=""
for s in /bin/bash /bin/ash /bin/sh /usr/bin/sh; do
  [ -x "$s" ] && SHELL="$s" && break
done

if [ "$CONSOLE" = "true" ] && [ -n "$SHELL" ]; then
  # Run app via catatonit in background (proper signal handling)
  /sbin/catatonit -- /fly/run.sh &
  APP_PID=$!

  # Spawn interactive shell on serial console
  echo '--- /fly/run.json with catatonit init successfully! ---'
  if setsid -c true 2>/dev/null; then
    setsid -c $SHELL </dev/ttyS0 >/dev/ttyS0 2>/dev/ttyS0 &
  else
    $SHELL </dev/ttyS0 >/dev/ttyS0 2>/dev/ttyS0 &
  fi

  # PID 1 must never exit — wait for app
  wait $APP_PID 2>/dev/null
  # If app dies, keep init alive (prevent kernel panic)
  while true; do sleep 3600; done
else
  # No console: exec through catatonit as PID 1
  exec /sbin/catatonit -- /fly/run.sh
fi
