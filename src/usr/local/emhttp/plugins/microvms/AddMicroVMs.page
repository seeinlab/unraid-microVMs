<div id="addOutput" style="display:none; margin-top:15px; padding:12px; background:#111; color:#0f0; font-family:monospace; font-size:12px; max-height:200px; overflow-y:auto; border-radius:4px;"></div>

<script>
$(function() {
  $('.autostart-add').switchButton({labels_placement:'right', on_label:'YES', off_label:'NO'});
  $('.console-add').switchButton({labels_placement:'right', on_label:'YES', off_label:'NO'});
});

function addEnvRow() {
  var div = document.createElement('div');
  div.className = 'env-row';
  div.innerHTML = '<input type="text" placeholder="KEY" class="env-key" style="width:150px;"> = <input type="text" placeholder="VALUE" class="env-val" style="width:250px;"> <input type="button" value="-" onclick="this.parentElement.remove()" style="width:30px;">';
  document.getElementById('env-vars').appendChild(div);
}
function addMountRow() {
  var div = document.createElement('div');
  div.className = 'mount-row';
  div.innerHTML = '<input type="text" placeholder="Tag" class="mount-tag" style="width:100px;"> <input type="text" placeholder="/host/path" class="mount-host" style="width:200px;"> <input type="text" placeholder="/guest/path" class="mount-guest" style="width:200px;"> <input type="button" value="-" onclick="this.parentElement.remove()" style="width:30px;">';
  document.getElementById('mounts-list').appendChild(div);
}

function toggleSource(val) {
  document.getElementById('section_oci').style.display = val === 'oci' ? '' : 'none';
  document.getElementById('section_existing').style.display = val === 'existing' ? '' : 'none';
}

function toggleDiskInput(sel) {
  var customInput = document.getElementById('vm_disk_size_custom');
  customInput.style.display = (sel.value === 'custom') ? 'inline-block' : 'none';
}

function toggleStorageFields() {
  var type = document.getElementById('vm_storage_type').value;
  var sourceRow = document.getElementById('row_rootfs_source');
  var diskSizeRow = document.getElementById('row_disk_size');
  var existingSection = document.getElementById('section_existing');
  if (type === 'thin') {
    sourceRow.style.display = 'none';
    diskSizeRow.style.display = 'none';
    existingSection.style.display = 'none';
    document.getElementById('section_oci').style.display = '';
  } else {
    sourceRow.style.display = '';
    diskSizeRow.style.display = '';
    toggleSource(document.getElementById('rootfs_source').value);
  }
}

toggleStorageFields();

function buildConfig() {
  var name = document.getElementById('vm_name').value;
  var mac = '52:54:00:' + ('0'+Math.floor(Math.random()*256).toString(16)).slice(-2) + ':' + ('0'+Math.floor(Math.random()*256).toString(16)).slice(-2) + ':' + ('0'+Math.floor(Math.random()*256).toString(16)).slice(-2);
  return {
    name: name,
    namespace: document.getElementById('vm_namespace').value,
    engine: $('input[name="engine"]:checked').val(),
    kernel: "<?=$vmdir?>/kernels/vmlinux",
    disk: "<?=$vmdir?>/" + document.getElementById('vm_namespace').value + "/" + name + "/rootfs.raw",
    cmdline: "console=ttyS0 root=/dev/vda rw init=/init ip=" + document.getElementById('vm_ip').value + "::" + document.getElementById('vm_gateway').value + ":255.255.255.0:::off",
    boot_vcpus: parseInt(document.getElementById('vm_cpus').value),
    max_vcpus: parseInt(document.getElementById('vm_max_cpus').value),
    memory_mb: parseInt(document.getElementById('vm_memory').value),
    mac: mac,
    ip: document.getElementById('vm_ip').value,
    bridge: "<?=$bridge?>",
    autostart: $('#vm_autostart').prop('checked')
  };
}

function toggleJson() {
  var s = document.getElementById('jsonSection');
  if (s.style.display === 'none') {
    s.style.display = '';
    document.getElementById('jsonBox').value = JSON.stringify(buildConfig(), null, 2);
  } else {
    s.style.display = 'none';
  }
}

function showProgress(msg) {
  var el = document.getElementById('addOutput');
  el.style.display = 'block';
  el.innerHTML += msg + '<br>';
  el.scrollTop = el.scrollHeight;
}

function submitForm() {
  var name = document.getElementById('vm_name').value;
  var source = document.getElementById('rootfs_source').value;
  var ociImage = document.getElementById('vm_oci_image').value;
  var storageType = document.getElementById('vm_storage_type').value;
  // Thin pool always uses OCI (source dropdown is hidden)
  if (storageType === 'thin') source = 'oci';

  // Show Docker-style progress popup
  var logHtml = '<div style="text-align:left;">';
  logHtml += '<div id="create-log" style="background:#1a1a2e;border:1px solid #333;border-radius:4px;padding:12px;font-family:monospace;font-size:12px;color:#0f0;max-height:300px;overflow-y:auto;min-height:120px;">';
  logHtml += '</div>';
  logHtml += '<div id="create-progress" style="margin-top:10px;background:#333;border-radius:3px;height:6px;overflow:hidden;display:none;">';
  logHtml += '<div id="create-bar" style="background:#4CAF50;height:100%;width:0%;transition:width 0.3s;"></div>';
  logHtml += '</div>';
  logHtml += '</div>';

  swal({title: 'Creating microVM: ' + name, text: logHtml, html: true, showConfirmButton: false, showCancelButton: false, closeOnConfirm: false, closeOnCancel: false});

  var log = document.getElementById('create-log');
  var bar = document.getElementById('create-bar');
  var prog = document.getElementById('create-progress');

  function addLine(msg, color) {
    var line = document.createElement('div');
    line.style.color = color || '#0f0';
    line.style.marginBottom = '2px';
    line.textContent = msg;
    log.appendChild(line);
    log.scrollTop = log.scrollHeight;
  }
  function setProgress(pct) {
    prog.style.display = '';
    bar.style.width = pct + '%';
  }

  addLine('$ create ' + name);
  addLine('VMM: ' + $('input[name="engine"]:checked').val());
  var engine = $('input[name="engine"]:checked').val();
  if (engine === 'cloud-hypervisor') {
    addLine('API: cloud-hypervisor v52.0 (ch-remote)', '#88c0d0');
  } else {
    addLine('API: firecracker v1.16.0 (REST /machine-config)', '#88c0d0');
  }
  addLine('Bridge: <?=$bridge?> | Memory: ' + document.getElementById('vm_memory').value + 'MB | vCPUs: ' + document.getElementById('vm_cpus').value);
  if (source === 'oci') {
    addLine('Pulling image: ' + ociImage + '...');
    if (storageType === 'thin') {
      addLine('  ctr images pull ' + ociImage + ' (containerd devmapper)', '#88c0d0');
    } else {
      addLine('  crane export ' + ociImage + ' → rootfs.tar', '#88c0d0');
    }
    setProgress(10);
  }
  addLine('Creating rootfs and config...');
  setProgress(20);

  // Collect env vars
  var env = {};
  $('.env-row').each(function() {
    var k = $(this).find('.env-key').val().trim();
    var v = $(this).find('.env-val').val();
    if (k) env[k] = v || '';
  });
  // Collect mounts
  var mounts = [];
  $('.mount-row').each(function() {
    var tag = $(this).find('.mount-tag').val().trim();
    var host = $(this).find('.mount-host').val().trim();
    var guest = $(this).find('.mount-guest').val().trim();
    if (tag && host && guest) mounts.push({tag: tag, host_path: host, guest_path: guest});
  });

  $.post('/plugins/<?=$plugin?>/backend/MicroVMAdmin.php', {
    cmd: 'create',
    name: name,
    namespace: document.getElementById('vm_namespace').value,
    engine: $('input[name="engine"]:checked').val(),
    cpus: document.getElementById('vm_cpus').value,
    max_cpus: document.getElementById('vm_max_cpus').value,
    memory: document.getElementById('vm_memory').value,
    max_memory: document.getElementById('vm_max_memory').value,
    ip: document.getElementById('vm_ip').value,
    gateway: document.getElementById('vm_gateway').value,
    source: source,
    oci_image: ociImage,
    disk_size: (document.getElementById('vm_disk_size').value === 'custom') ? document.getElementById('vm_disk_size_custom').value : document.getElementById('vm_disk_size').value,
    storage_type: document.getElementById('vm_storage_type').value,
    rootfs_path: document.getElementById('vm_rootfs_path').value,
    autostart: $('#vm_autostart').prop('checked') ? 'true' : 'false',
    console: $('#vm_console').prop('checked') ? 'true' : 'false',
    env: JSON.stringify(env),
    mounts: JSON.stringify(mounts)
  }, function(data) {
    var result = (typeof data === 'object') ? data : JSON.parse(data);
    setProgress(100);
    addLine('');
    if (result.success) {
      if (result.started) {
        addLine('✓ ' + result.message, '#4CAF50');
        if (result.output) {
          var lines = result.output.split('\n');
          for (var i = 0; i < lines.length; i++) {
            if (lines[i].trim()) addLine('  ' + lines[i].trim(), '#88c0d0');
          }
        }
      } else {
        addLine('⚠ ' + result.message, '#ff9800');
        if (result.output) addLine('  ' + result.output, '#ff9800');
      }
      setTimeout(function() {
        swal.close();
        location = '/MicroVMs';
      }, 2500);
    } else {
      addLine('✗ ' + (result.error || 'Unknown error'), '#f44336');
      // Show close button on error
      setTimeout(function() {
        var btn = document.createElement('button');
        btn.textContent = 'CLOSE';
        btn.style.cssText = 'margin-top:12px;padding:8px 24px;border:1px solid #f44336;background:transparent;color:#f44336;border-radius:3px;cursor:pointer;font-weight:bold;';
        btn.onclick = function() { swal.close(); };
        log.parentNode.appendChild(btn);
      }, 300);
    }
  }).fail(function(xhr) {
    setProgress(100);
    bar.style.background = '#f44336';
    addLine('');
    addLine('✗ Request failed: ' + xhr.statusText, '#f44336');
    setTimeout(function() {
      var btn = document.createElement('button');
      btn.textContent = 'CLOSE';
      btn.style.cssText = 'margin-top:12px;padding:8px 24px;border:1px solid #f44336;background:transparent;color:#f44336;border-radius:3px;cursor:pointer;font-weight:bold;';
      btn.onclick = function() { swal.close(); };
      log.parentNode.appendChild(btn);
    }, 300);
  });
  return false;
}

function createFromJson() {
  var json = document.getElementById('jsonBox').value;
  try { JSON.parse(json); } catch(e) { alert('Invalid JSON: ' + e.message); return; }
  showProgress('Creating from JSON...');
  $.post('/plugins/<?=$plugin?>/backend/MicroVMAdmin.php', {cmd: 'create_json', config: json}, function(data) {
    var r = (typeof data === 'object') ? data : JSON.parse(data);
    if (r.success) {
      showProgress('<b style="color:#4CAF50;">✓ Created!</b>');
      setTimeout(function(){ location = '/MicroVMs'; }, 2000);
    } else {
      showProgress('<b style="color:#f44336;">✗ ' + (r.error || 'Failed') + '</b>');
    }
  });
}

function done() { location = '/MicroVMs'; }

$('input[name="engine"]').change(function() {
  $('#label_ch').css({'border-color': '#555', 'background': 'transparent'});
  $('#label_fc').css({'border-color': '#555', 'background': 'transparent'});
  var nsSel = document.getElementById('vm_namespace');
  if ($('#engine_ch').is(':checked')) {
    $('#label_ch').css({'border-color': '#4CAF50', 'background': '#1a2e1a'});
    $('#row_max_memory').show();
    $('#row_max_cpus').show();
    $('#row_mounts').show();
    // Default namespace to 'ch' for Cloud Hypervisor
    if (nsSel.querySelector('option[value="ch"]')) nsSel.value = 'ch';
  } else {
    $('#label_fc').css({'border-color': '#ff9800', 'background': '#2e2a1a'});
    $('#row_max_memory').hide();
    $('#row_max_cpus').hide();
    $('#row_mounts').hide();
    // Default namespace to 'fc' for Firecracker
    if (nsSel.querySelector('option[value="fc"]')) nsSel.value = 'fc';
  }
});

// Show/hide max memory based on initial engine selection
$(function() {
  if ($('#engine_fc').is(':checked')) {
    $('#row_max_memory').hide();
    $('#row_mounts').hide();
  }
  // Set initial namespace based on selected engine
  var nsSel = document.getElementById('vm_namespace');
  if ($('#engine_ch').is(':checked') && nsSel.querySelector('option[value="ch"]')) {
    nsSel.value = 'ch';
  } else if ($('#engine_fc').is(':checked') && nsSel.querySelector('option[value="fc"]')) {
    nsSel.value = 'fc';
  }
  updateMaxMemory();
});

function updateMaxMemory() {
  var memVal = parseInt(document.getElementById('vm_memory').value);
  var maxSel = document.getElementById('vm_max_memory');
  var allOptions = [
    {value: 128, label: '128 MB'},
    {value: 256, label: '256 MB'},
    {value: 512, label: '512 MB'},
    {value: 1024, label: '1.0 GB'},
    {value: 2048, label: '2.0 GB'},
    {value: 4096, label: '4.0 GB'},
    {value: 8192, label: '8.0 GB'},
    {value: 16384, label: '16.0 GB'},
    {value: 32768, label: '32.0 GB'}
  ];
  var currentMax = parseInt(maxSel.value);
  maxSel.innerHTML = '';
  var defaultVal = memVal * 2;
  var hasSelected = false;
  for (var i = 0; i < allOptions.length; i++) {
    if (allOptions[i].value >= memVal) {
      var opt = document.createElement('option');
      opt.value = allOptions[i].value;
      opt.textContent = allOptions[i].label;
      if (allOptions[i].value === currentMax && currentMax >= memVal) {
        opt.selected = true;
        hasSelected = true;
      } else if (!hasSelected && allOptions[i].value >= defaultVal) {
        opt.selected = true;
        hasSelected = true;
      }
      maxSel.appendChild(opt);
    }
  }
}
</script>
