Title="Add microVM"
Cond="is_file('/usr/local/bin/flintlockd')"
Markdown="false"
---
<?php
$plugin = "microvms";
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/$plugin/include/common.php";

$cfg = microvm_load_config();
$vmdir = $cfg['VMDIR'] ?? '/mnt/user/microvms';
$bridge = $cfg['BRIDGE'] ?? 'br0';
$default_cpus = $cfg['DEFAULT_CPUS'] ?? '1';
$default_mem = $cfg['DEFAULT_MEMORY'] ?? '256';
$nproc = trim(shell_exec('nproc'));
?>

<link type="text/css" rel="stylesheet" href="<?autov('/webGui/styles/jquery.switchbutton.css')?>">
<script src="<?autov('/webGui/javascript/jquery.switchbutton.js')?>"></script>

<div class="title"><span class="left"><a href="/MicroVMs" title="Back to microVMs"><i class="fa fa-arrow-left"></i></a> Add microVM</span></div>

<form id="microvm_add_form" onsubmit="return submitForm()">

<dl>
  <dt>VMM:</dt>
  <dd>
    <div style="display:inline-flex; gap:15px; align-items:center;">
      <label style="cursor:pointer; text-align:center; padding:8px 16px; border:2px solid #4CAF50; border-radius:8px; background:#1a2e1a;" id="label_ch">
        <input type="radio" name="engine" id="engine_ch" value="cloud-hypervisor" checked style="display:none;">
        <img src="/plugins/microvms/images/cloud-hypervisor.png" style="width:40px; height:40px; object-fit:contain; display:block; margin:0 auto 4px;">
        <span style="font-size:11px;">Cloud Hypervisor</span>
      </label>
      <label style="cursor:pointer; text-align:center; padding:8px 16px; border:2px solid #555; border-radius:8px;" id="label_fc">
        <input type="radio" name="engine" id="engine_fc" value="firecracker" style="display:none;">
        <img src="/plugins/microvms/images/firecracker.png" style="width:40px; height:40px; object-fit:contain; display:block; margin:0 auto 4px;">
        <span style="font-size:11px;">Firecracker</span>
      </label>
    </div>
  </dd>
</dl>

<dl>
  <dt>Autostart:</dt>
  <dd><input class="autostart-add" type="checkbox" id="vm_autostart"></dd>
</dl>

<dl>
  <dt>Name:</dt>
  <dd><input type="text" id="vm_name" required placeholder="my-web-server" pattern="[a-z0-9\-]+" title="lowercase, numbers, hyphens" style="width:300px;"></dd>
</dl>

<dl>
  <dt>vCPUs:</dt>
  <dd><select id="vm_cpus" style="width:80px;">
    <?php for ($i = 1; $i <= $nproc; $i++): ?>
    <option value="<?=$i?>" <?=($i == $default_cpus) ? 'selected' : ''?>><?=$i?></option>
    <?php endfor; ?>
  </select></dd>
</dl>

<dl>
  <dt>Initial Memory:</dt>
  <dd><select id="vm_memory" style="width:120px;">
    <option value="128">128 MB</option>
    <option value="256" selected>256 MB</option>
    <option value="512">512 MB</option>
    <option value="1024">1.0 GB</option>
    <option value="2048">2.0 GB</option>
    <option value="4096">4.0 GB</option>
    <option value="8192">8.0 GB</option>
  </select></dd>
</dl>

<dl>
  <dt>IP Address:</dt>
  <dd><input type="text" id="vm_ip" required placeholder="<?=trim(shell_exec("ip -4 addr show $bridge 2>/dev/null | grep -oP 'inet \K[\d.]+/\d+' | sed 's|\.[0-9]*/|.x/|'"))?>" style="width:200px;"></dd>
</dl>

<dl>
  <dt>Gateway:</dt>
  <dd><input type="text" id="vm_gateway" placeholder="<?=trim(shell_exec("ip route | grep default | grep -oP 'via \K[\d.]+' | head -1"))?>" style="width:200px;"></dd>
</dl>

<dl>
  <dt>rootFS Source:</dt>
  <dd>
    <select id="rootfs_source" onchange="toggleSource(this.value)" style="width:320px;">
      <option value="oci">Pull OCI/Docker Image (via crane)</option>
      <option value="existing">Use Existing rootfs</option>
    </select>
  </dd>
</dl>

<div id="section_oci">
<dl>
  <dt>OCI/Docker Image:</dt>
  <dd><input type="text" id="vm_oci_image" placeholder="docker.io/nginx:alpine" style="width:300px;"></dd>
</dl>
<dl>
  <dt>Disk Size:</dt>
  <dd><select id="vm_disk_size" style="width:120px;">
    <option value="200">200 MB</option>
    <option value="500" selected>500 MB</option>
    <option value="1024">1.0 GB</option>
    <option value="2048">2.0 GB</option>
    <option value="5120">5.0 GB</option>
  </select></dd>
</dl>
<dl>
  <dt>Storage Type:</dt>
  <dd><select id="vm_storage_type" style="width:200px;">
    <option value="thin">Thin Pool (block device)</option>
    <option value="raw">Raw File (rootfs.raw)</option>
  </select></dd>
</dl>
</div>

<div id="section_existing" style="display:none;">
<dl>
  <dt>rootFS Path:</dt>
  <dd><input type="text" id="vm_rootfs_path" placeholder="<?=$vmdir?>/myvm/rootfs.raw" style="width:400px;"></dd>
</dl>
</div>

<br>
<dl>
  <dt>&nbsp;</dt>
  <dd><span style="display:inline-flex; gap:10px;"><input type="submit" value="Create" style="display:inline-block;width:auto;"><input type="button" value="Done" onclick="done()" style="display:inline-block;width:auto;"><input type="button" value="Show JSON" onclick="toggleJson()" style="display:inline-block;width:auto;"></span></dd>
</dl>

</form>

<div id="jsonSection" style="display:none; margin-top:15px; padding:0 30px;">
<textarea id="jsonBox" style="width:80%; min-height:200px; font-family:monospace; font-size:12px; padding:10px; background:#0d1117; color:#c9d1d9; border:1px solid #30363d; border-radius:4px;" spellcheck="false"></textarea>
<br><br>
<input type="button" value="Create from JSON" onclick="createFromJson()">
</div>

<div id="addOutput" style="display:none; margin-top:15px; padding:12px; background:#111; color:#0f0; font-family:monospace; font-size:12px; max-height:200px; overflow-y:auto; border-radius:4px;"></div>

<script>
$(function() {
  $('.autostart-add').switchButton({labels_placement:'right', on_label:'YES', off_label:'NO'});
});

function toggleSource(val) {
  document.getElementById('section_oci').style.display = val === 'oci' ? '' : 'none';
  document.getElementById('section_existing').style.display = val === 'existing' ? '' : 'none';
}

function buildConfig() {
  var name = document.getElementById('vm_name').value;
  var mac = '52:54:00:' + ('0'+Math.floor(Math.random()*256).toString(16)).slice(-2) + ':' + ('0'+Math.floor(Math.random()*256).toString(16)).slice(-2) + ':' + ('0'+Math.floor(Math.random()*256).toString(16)).slice(-2);
  return {
    name: name,
    engine: $('input[name="engine"]:checked').val(),
    kernel: "<?=$vmdir?>/kernels/vmlinux",
    disk: "<?=$vmdir?>/" + name + "/rootfs.raw",
    cmdline: "console=ttyS0 root=/dev/vda rw init=/init ip=" + document.getElementById('vm_ip').value + "::" + document.getElementById('vm_gateway').value + ":255.255.255.0:::off",
    boot_vcpus: parseInt(document.getElementById('vm_cpus').value),
    max_vcpus: parseInt(document.getElementById('vm_cpus').value) * 2,
    memory_mb: parseInt(document.getElementById('vm_memory').value),
    mac: mac,
    ip: document.getElementById('vm_ip').value,
    bridge: "<?=$bridge?>",
    autostart: $('#vm_autostart').prop('checked')
  };
}

function toggleJson() {
  var s = document.getElementById('jsonSection');
  if (s.style.display === 'none') {
    s.style.display = '';
    document.getElementById('jsonBox').value = JSON.stringify(buildConfig(), null, 2);
  } else {
    s.style.display = 'none';
  }
}

function showProgress(msg) {
  var el = document.getElementById('addOutput');
  el.style.display = 'block';
  el.innerHTML += msg + '<br>';
  el.scrollTop = el.scrollHeight;
}

function submitForm() {
  var name = document.getElementById('vm_name').value;
  var source = document.getElementById('rootfs_source').value;
  var ociImage = document.getElementById('vm_oci_image').value;

  // Show Docker-style progress popup
  var logHtml = '<div style="text-align:left;">';
  logHtml += '<div id="create-log" style="background:#1a1a2e;border:1px solid #333;border-radius:4px;padding:12px;font-family:monospace;font-size:12px;color:#0f0;max-height:300px;overflow-y:auto;min-height:120px;">';
  logHtml += '</div>';
  logHtml += '<div id="create-progress" style="margin-top:10px;background:#333;border-radius:3px;height:6px;overflow:hidden;display:none;">';
  logHtml += '<div id="create-bar" style="background:#4CAF50;height:100%;width:0%;transition:width 0.3s;"></div>';
  logHtml += '</div>';
  logHtml += '</div>';

  swal({title: 'Creating microVM: ' + name, text: logHtml, html: true, showConfirmButton: false, showCancelButton: false, closeOnConfirm: false, closeOnCancel: false});

  var log = document.getElementById('create-log');
  var bar = document.getElementById('create-bar');
  var prog = document.getElementById('create-progress');

  function addLine(msg, color) {
    var line = document.createElement('div');
    line.style.color = color || '#0f0';
    line.style.marginBottom = '2px';
    line.textContent = msg;
    log.appendChild(line);
    log.scrollTop = log.scrollHeight;
  }
  function setProgress(pct) {
    prog.style.display = '';
    bar.style.width = pct + '%';
  }

  addLine('$ create ' + name);
  addLine('VMM: ' + $('input[name="engine"]:checked').val());
  var engine = $('input[name="engine"]:checked').val();
  if (engine === 'cloud-hypervisor') {
    addLine('API: cloud-hypervisor v52.0 (ch-remote)', '#88c0d0');
  } else {
    addLine('API: firecracker v1.16.0 (REST /machine-config)', '#88c0d0');
  }
  addLine('Bridge: <?=$bridge?> | Memory: ' + document.getElementById('vm_memory').value + 'MB | vCPUs: ' + document.getElementById('vm_cpus').value);
  if (source === 'oci') {
    addLine('Pulling image: ' + ociImage + '...');
    addLine('  crane export ' + ociImage + ' → rootfs.tar', '#88c0d0');
    setProgress(10);
  }
  addLine('Creating rootfs and config...');
  setProgress(20);

  $.post('/plugins/<?=$plugin?>/backend/MicroVMAdmin.php', {
    cmd: 'create',
    name: name,
    engine: $('input[name="engine"]:checked').val(),
    cpus: document.getElementById('vm_cpus').value,
    memory: document.getElementById('vm_memory').value,
    ip: document.getElementById('vm_ip').value,
    gateway: document.getElementById('vm_gateway').value,
    source: source,
    oci_image: ociImage,
    disk_size: document.getElementById('vm_disk_size').value,
    storage_type: document.getElementById('vm_storage_type').value,
    rootfs_path: document.getElementById('vm_rootfs_path').value,
    autostart: $('#vm_autostart').prop('checked') ? 'true' : 'false'
  }, function(data) {
    var result = (typeof data === 'object') ? data : JSON.parse(data);
    setProgress(100);
    addLine('');
    if (result.success) {
      if (result.started) {
        addLine('✓ ' + result.message, '#4CAF50');
        if (result.output) {
          var lines = result.output.split('\n');
          for (var i = 0; i < lines.length; i++) {
            if (lines[i].trim()) addLine('  ' + lines[i].trim(), '#88c0d0');
          }
        }
      } else {
        addLine('⚠ ' + result.message, '#ff9800');
        if (result.output) addLine('  ' + result.output, '#ff9800');
      }
      setTimeout(function() {
        swal.close();
        location = '/MicroVMs';
      }, 2500);
    } else {
      addLine('✗ ' + (result.error || 'Unknown error'), '#f44336');
      // Show close button on error
      setTimeout(function() {
        var btn = document.createElement('button');
        btn.textContent = 'CLOSE';
        btn.style.cssText = 'margin-top:12px;padding:8px 24px;border:1px solid #f44336;background:transparent;color:#f44336;border-radius:3px;cursor:pointer;font-weight:bold;';
        btn.onclick = function() { swal.close(); };
        log.parentNode.appendChild(btn);
      }, 300);
    }
  }).fail(function(xhr) {
    setProgress(100);
    bar.style.background = '#f44336';
    addLine('');
    addLine('✗ Request failed: ' + xhr.statusText, '#f44336');
    setTimeout(function() {
      var btn = document.createElement('button');
      btn.textContent = 'CLOSE';
      btn.style.cssText = 'margin-top:12px;padding:8px 24px;border:1px solid #f44336;background:transparent;color:#f44336;border-radius:3px;cursor:pointer;font-weight:bold;';
      btn.onclick = function() { swal.close(); };
      log.parentNode.appendChild(btn);
    }, 300);
  });
  return false;
}

function createFromJson() {
  var json = document.getElementById('jsonBox').value;
  try { JSON.parse(json); } catch(e) { alert('Invalid JSON: ' + e.message); return; }
  showProgress('Creating from JSON...');
  $.post('/plugins/<?=$plugin?>/backend/MicroVMAdmin.php', {cmd: 'create_json', config: json}, function(data) {
    var r = (typeof data === 'object') ? data : JSON.parse(data);
    if (r.success) {
      showProgress('<b style="color:#4CAF50;">✓ Created!</b>');
      setTimeout(function(){ location = '/MicroVMs'; }, 2000);
    } else {
      showProgress('<b style="color:#f44336;">✗ ' + (r.error || 'Failed') + '</b>');
    }
  });
}

function done() { location = '/MicroVMs'; }

$('input[name="engine"]').change(function() {
  $('#label_ch').css({'border-color': '#555', 'background': 'transparent'});
  $('#label_fc').css({'border-color': '#555', 'background': 'transparent'});
  if ($('#engine_ch').is(':checked')) {
    $('#label_ch').css({'border-color': '#4CAF50', 'background': '#1a2e1a'});
  } else {
    $('#label_fc').css({'border-color': '#ff9800', 'background': '#2e2a1a'});
  }
});
</script>
