<script>
var plugin = '<?=$plugin?>';

function addMicroVMContext(name, state, engine) {
  var opts = [];
  context.settings({right:false, above:false});

  if (state == 'running') {
    if (engine == 'cloud-hypervisor') {
      opts.push({text:'Stop', icon:'fa-stop', action:function(e){
        e.preventDefault();
        vmAction('stop', name);
      }});
    }
    opts.push({text:'Force Stop', icon:'fa-power-off', action:function(e){
      e.preventDefault();
      vmAction('force_stop', name);
    }});
    opts.push({text:'Console', icon:'fa-terminal', action:function(e){
      e.preventDefault();
      vmConsole(name);
    }});
    if (engine == 'cloud-hypervisor') {
      opts.push({text:'Edit', icon:'fa-pencil', action:function(e){
        e.preventDefault();
        vmResize(name, engine);
      }});
    }
    opts.push({text:'Create Snapshot', icon:'fa-camera', action:function(e){
      e.preventDefault();
      vmAction('snapshot', name);
    }});
    opts.push({text:'Snapshots', icon:'fa-history', action:function(e){
      e.preventDefault();
      vmSnapshots(name);
    }});
    opts.push({text:'Info', icon:'fa-info-circle', action:function(e){
      e.preventDefault();
      vmInfo(name);
    }});
  } else {
    opts.push({text:'Start', icon:'fa-play', action:function(e){
      e.preventDefault();
      vmAction('start', name);
    }});
    opts.push({text:'Snapshots', icon:'fa-history', action:function(e){
      e.preventDefault();
      vmSnapshots(name);
    }});
    opts.push({text:'Info', icon:'fa-info-circle', action:function(e){
      e.preventDefault();
      vmInfo(name);
    }});
    opts.push({divider:true});
    opts.push({text:'Remove microVM', icon:'fa-trash', action:function(e){
      e.preventDefault();
      vmDelete(name, state);
    }});
  }

  context.destroy('#vm-' + name);
  context.attach('#vm-' + name, opts);
}

function addmicroVM() {
  location = location.pathname + '/AddMicroVMs';
}

function vmAction(action, name) {
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: action, name: name}, function(data) {
    if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
    if (data.acpi_timeout) {
      swal({
        title: 'ACPI Timeout',
        text: "microVM '" + name + "' did not respond to ACPI power-button within 90 seconds.\n\nThe VM may not have an ACPI daemon installed. Use Force Stop to terminate it.",
        type: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Force Stop',
        cancelButtonText: 'Cancel'
      }, function(confirmed) {
        if (confirmed) {
          $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'force_stop', name: name}, function() {
            location.reload();
          });
        }
      });
    } else {
      setTimeout(function(){ location.reload(); }, 1500);
    }
  });
}

function vmConsole(name) {
  var html = '<div id="console-wrap" style="text-align:left;width:100%;">' +
    '<pre id="console-output" style="height:400px;overflow-y:scroll;font-size:11px;white-space:pre-wrap;word-break:break-all;background:#0d1117;padding:12px;border-radius:4px;color:#c9d1d9;border:1px solid #30363d;"></pre>' +
    '<div id="console-input-row" style="margin-top:8px;display:flex;gap:8px;align-items:center;width:100%;"></div>' +
  '</div>';

  swal({
    title: name + ' — Console',
    text: html,
    html: true,
    showConfirmButton: true,
    confirmButtonText: 'Close',
    allowOutsideClick: true
  });

  setTimeout(function() {
    // Center and widen modal
    var modal = document.querySelector('.sweet-alert');
    if (modal) {
      modal.style.width = '85%';
      modal.style.maxWidth = '960px';
      modal.style.position = 'fixed';
      modal.style.top = '50%';
      modal.style.left = '50%';
      modal.style.transform = 'translate(-50%, -50%)';
      modal.style.margin = '0';
      modal.style.resize = 'both';
      modal.style.overflow = 'auto';
    }

    // Inject input via DOM (swal strips <input> from HTML)
    var row = document.getElementById('console-input-row');
    if (row) {
      row.innerHTML = '';
      var inp = document.createElement('textarea');
      inp.id = 'console-input';
      inp.rows = 1;
      inp.placeholder = 'command...';
      inp.style.cssText = 'width:calc(100% - 100px);background:#0d1117;color:#3fb950;border:1px solid #3fb950;padding:8px 12px;font-family:monospace;font-size:13px;border-radius:4px;outline:none;resize:none;overflow:hidden;vertical-align:middle;';
      row.appendChild(inp);
      var btn = document.createElement('button');
      btn.textContent = 'Send';
      btn.style.cssText = 'background:#238636;color:#fff;border:none;padding:8px 16px;border-radius:4px;cursor:pointer;font-size:12px;';
      row.appendChild(btn);
      inp.focus();

      // Refresh output
      var output = document.getElementById('console-output');
      var refreshOutput = function() {
        $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'console_output', name: name}, function(data) {
          if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
          if (data && data.success && output) {
            output.textContent = data.log || '';
            output.scrollTop = output.scrollHeight;
          }
        });
      };

      // Send command
      var sendCommand = function() {
        var cmd = inp.value.trim();
        if (!cmd) return;
        inp.value = '';
        inp.focus();
        $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'console_input', name: name, input: cmd}, function() {
          setTimeout(refreshOutput, 400);
          setTimeout(refreshOutput, 1200);
        });
      };

      inp.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); sendCommand(); } });
      btn.addEventListener('click', sendCommand);

      refreshOutput();
      var interval = setInterval(refreshOutput, 2000);
      document.querySelector('.sweet-alert .confirm').addEventListener('click', function() { clearInterval(interval); });
    }
  }, 250);
}

function vmResize(name, engine) {
  if (engine === 'firecracker') {
    swal({title: 'Not Supported', text: 'Live edit is not supported for Firecracker.', type: 'error'});
    return;
  }
  // Load current config to get limits
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'vm_config', name: name}, function(data) {
    if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
    var curCpus = data.vcpus || 1;
    var maxCpus = data.max_vcpus || (curCpus * 2);
    var curMem = data.memory_mb || 256;
    var maxMem = data.max_memory_mb || (curMem * 2);

    var html = '<div style="text-align:left;">' +
      '<div style="margin-bottom:12px;"><label style="display:block;font-weight:bold;margin-bottom:4px;">vCPUs (current: ' + curCpus + ', max: ' + maxCpus + '):</label>' +
      '<span id="edit-cpus-val" style="display:inline-block;width:30px;text-align:center;font-weight:bold;">' + curCpus + '</span>' +
      '<input id="edit-cpus" type="range" min="1" max="' + maxCpus + '" value="' + curCpus + '" style="width:80%;vertical-align:middle;" oninput="document.getElementById(\'edit-cpus-val\').textContent=this.value"></div>' +
      '<div><label style="display:block;font-weight:bold;margin-bottom:4px;">Memory MB (current: ' + curMem + ', max: ' + maxMem + '):</label>' +
      '<span id="edit-mem-val" style="display:inline-block;width:50px;text-align:center;font-weight:bold;">' + curMem + '</span>' +
      '<input id="edit-mem" type="range" min="128" max="' + maxMem + '" step="128" value="' + curMem + '" style="width:75%;vertical-align:middle;" oninput="document.getElementById(\'edit-mem-val\').textContent=this.value"></div>' +
    '</div>';
    swal({
      title: 'Edit ' + name,
      text: html,
      html: true,
      showCancelButton: true,
      confirmButtonText: 'Apply',
      closeOnConfirm: false
    }, function() {
      var cpus = document.getElementById('edit-cpus').value;
      var memMB = document.getElementById('edit-mem').value;
      var memBytes = parseInt(memMB) * 1048576;
      swal({title: 'Applying...', text: cpus + ' CPUs, ' + memMB + ' MB', showConfirmButton: false});
      $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd:'resize', name:name, cpus:cpus, memory:memBytes}, function(data) {
        if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
        if (data.cpus || data.memory) {
          swal({title: 'Applied!', text: 'CPUs: ' + (data.cpus ? 'OK' : 'failed') + ', Memory: ' + (data.memory ? 'OK' : 'failed'), type: 'success'}, function() {
            location.reload();
          });
        } else {
          swal({title: 'Edit Failed', text: JSON.stringify(data), type: 'error'});
        }
      });
    });
  });
}

function vmInfo(name) {
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'info', name: name}, function(data) {
    var text;
    if (typeof data === 'object') {
      text = JSON.stringify(data, null, 2);
    } else {
      try { text = JSON.stringify(JSON.parse(data), null, 2); } catch(e) { text = data; }
    }
    swal({title: name, text: '<pre style="text-align:left;max-height:400px;overflow:auto;font-size:12px;">' + text + '</pre>', html: true});
  });
}

function vmVmmLogs(name, engine) {
  var service = (engine || 'cloud-hypervisor') + '/' + name;
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'view_log', service: service}, function(data) {
    if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
    if (data && data.success) {
      swal({title: name + ' — Logs', text: '<pre style="text-align:left;max-height:400px;overflow:auto;font-size:11px;white-space:pre-wrap;word-break:break-all;background:#1a1a2e;padding:12px;border-radius:4px;color:#ccc;">' + (data.log || '(empty)') + '</pre>', html: true, confirmButtonText: 'Close'});
    } else {
      swal({title: 'VMM Logs Error', text: (data && data.error) || 'Failed to load VMM logs', type: 'error'});
    }
  });
}

function vmDelete(name, state) {
  if (state === 'running') {
    swal({title: 'Cannot Delete', text: "VM '" + name + "' is running. Stop it first.", type: 'error'});
    return;
  }
  // Check for snapshots via backend
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'list_snapshots', name: name}, function(data) {
    if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
    var snaps = (data.snapshots || []).length;
    if (snaps > 0) {
      swal({title: 'Cannot Delete', text: "VM '" + name + "' has " + snaps + " snapshot(s). Remove them first.", type: 'error'});
      return;
    }
    swal({
      title: 'Delete ' + name + '?',
      text: 'This will delete the VM and all its data (config, rootfs). This cannot be undone.',
      type: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Delete',
      cancelButtonText: 'Cancel'
    }, function(confirmed) {
      if (confirmed) {
        $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'delete', name: name}, function(data) {
          if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
          if (data.success) {
            swal({title: 'Deleted', text: data.message, type: 'success'}, function() { location.reload(); });
          } else {
            swal({title: 'Error', text: data.error || 'Delete failed', type: 'error'});
          }
        });
      }
    });
  });
}

// Initialize switchButton for autostart toggles
$(function() {
  $('.autostart').switchButton({labels_placement:'right', on_label:'On', off_label:'Off'});
  $('.autostart').change(function() {
    var name = $(this).data('name');
    var enabled = $(this).prop('checked') ? 'true' : 'false';
    $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'autostart', name: name, enabled: enabled});
  });
});

function startAll() {
  <?php foreach ($vms as $vm): ?>
    <?php if ($vm['state'] !== 'running'): ?>
    vmAction('start', '<?=htmlspecialchars($vm['name'])?>');
    <?php endif; ?>
  <?php endforeach; ?>
}

function stopAll() {
  <?php foreach ($vms as $vm): ?>
    <?php if ($vm['state'] === 'running'): ?>
    vmAction('stop', '<?=htmlspecialchars($vm['name'])?>');
    <?php endif; ?>
  <?php endforeach; ?>
}

function vmSnapshots(name) {
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'list_snapshots', name: name}, function(data) {
    if (!data.success) {
      swal({title: 'Error', text: data.error || 'Failed to list snapshots', type: 'error'});
      return;
    }
    var snaps = data.snapshots || [];
    var html = '<div style="text-align:left;max-height:400px;overflow-y:auto;">';

    if (snaps.length === 0) {
      html += '<p style="text-align:center;color:#999;">No snapshots for this VM.</p>';
      html += '<p style="text-align:center;font-size:0.85em;color:#666;">Create one using the <b>Snapshot</b> action while the VM is running.</p>';
    } else {
      html += '<table style="width:100%;border-collapse:collapse;font-size:0.9em;">';
      html += '<tr style="border-bottom:1px solid #444;"><th style="padding:6px;text-align:left;">Tag / Date</th><th style="padding:6px;text-align:left;">Size</th><th style="padding:6px;text-align:right;">Actions</th></tr>';
      for (var i = 0; i < snaps.length; i++) {
        var s = snaps[i];
        html += '<tr style="border-bottom:1px solid #333;">';
        html += '<td style="padding:6px;"><b>' + escapeHtml(s.tag) + '</b><br><span style="font-size:0.8em;color:#999;">' + escapeHtml(s.date) + '</span></td>';
        html += '<td style="padding:6px;color:#ccc;">' + escapeHtml(s.size) + '</td>';
        html += '<td style="padding:6px;text-align:right;">';
        html += '<a href="#" onclick="vmSnapshotRestore(\'' + escapeHtml(name) + '\',\'' + escapeHtml(s.tag) + '\');return false;" style="color:#4caf50;margin-right:12px;" title="Restore"><i class="fa fa-undo"></i> Restore</a>';
        html += '<a href="#" onclick="vmSnapshotDelete(\'' + escapeHtml(name) + '\',\'' + escapeHtml(s.tag) + '\');return false;" style="color:#ef5350;" title="Delete"><i class="fa fa-trash"></i> Delete</a>';
        html += '</td></tr>';
      }
      html += '</table>';
    }
    html += '</div>';

    swal({
      title: name + ' — Snapshots (' + snaps.length + ')',
      text: html,
      html: true,
      showCancelButton: false,
      confirmButtonText: 'Close'
    });
  });
}

function vmSnapshotRestore(name, tag) {
  swal({
    title: 'Restore Snapshot?',
    text: 'This will stop the current VM and restore from snapshot <b>' + escapeHtml(tag) + '</b>.<br><br>Any unsaved state in the running VM will be lost.',
    html: true,
    type: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Restore',
    cancelButtonText: 'Cancel',
    closeOnConfirm: false
  }, function(confirmed) {
    if (confirmed) {
      swal({title: 'Restoring...', text: 'Please wait while the VM is restored from snapshot.', showConfirmButton: false});
      $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'restore_snapshot', name: name, tag: tag}, function(data) {
        if (data.success) {
          swal({title: 'Restored!', text: data.message, type: 'success'}, function() {
            location.reload();
          });
        } else {
          swal({title: 'Restore Failed', text: data.error || data.message || 'Unknown error', type: 'error'});
        }
      }).fail(function() {
        swal({title: 'Error', text: 'Request failed. Check server logs.', type: 'error'});
      });
    }
  });
}

function vmSnapshotDelete(name, tag) {
  swal({
    title: 'Delete Snapshot?',
    text: 'Delete snapshot <b>' + escapeHtml(tag) + '</b>? This cannot be undone.',
    html: true,
    type: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Delete',
    cancelButtonText: 'Cancel',
    closeOnConfirm: false
  }, function(confirmed) {
    if (confirmed) {
      $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'delete_snapshot', name: name, tag: tag}, function(data) {
        if (data.success) {
          swal({title: 'Deleted', text: data.message, type: 'success'}, function() {
            vmSnapshots(name); // Refresh the list
          });
        } else {
          swal({title: 'Delete Failed', text: data.error || 'Unknown error', type: 'error'});
        }
      }).fail(function() {
        swal({title: 'Error', text: 'Request failed. Check server logs.', type: 'error'});
      });
    }
  });
}

function escapeHtml(str) {
  var div = document.createElement('div');
  div.appendChild(document.createTextNode(str));
  return div.innerHTML;
}

function showOutput(msg) {
  var el = document.getElementById('vmOutput');
  el.style.display = 'block';
  var line = document.createElement('div');
  line.textContent = msg;
  el.appendChild(line);
  el.scrollTop = el.scrollHeight;
}
</script>
