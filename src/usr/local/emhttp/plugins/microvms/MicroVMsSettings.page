<?php
$plugin = "microvms";
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/$plugin/include/common.php";

$cfg = microvm_load_config();
$vmdir = $cfg['VMDIR'] ?? '/mnt/user/microvms';
$kernelDir = "/mnt/user/system/microvms";

// --- Component status checks ---
$flintlockd_bin = is_file('/usr/local/bin/flintlockd');
$flintlockd_running = !empty(trim(shell_exec('pgrep -f flintlockd 2>/dev/null')));
$flintlockd_version = $flintlockd_bin ? trim(shell_exec('flintlockd version 2>/dev/null')) : false;

$containerd_bin = is_file('/usr/local/bin/flintlock-containerd');
$containerd_running = !empty(trim(shell_exec('pgrep -f flintlock-containerd 2>/dev/null')));
$containerd_version = $containerd_bin ? trim(shell_exec('flintlock-containerd --version 2>/dev/null | head -1')) : false;

$ch_bin = is_file('/usr/local/bin/cloud-hypervisor');
$ch_version = $ch_bin ? trim(shell_exec('cloud-hypervisor --version 2>/dev/null')) : false;
$ch_kernel = is_file("$kernelDir/cloud-hypervisor/kernels/vmlinux");
$ch_kernel_size = $ch_kernel ? round(filesize("$kernelDir/cloud-hypervisor/kernels/vmlinux") / 1048576) . ' MB' : false;
$ch_kernel_ver = $ch_kernel ? trim(shell_exec("grep -aoP 'Linux version \\K[\\d.]+' " . escapeshellarg("$kernelDir/cloud-hypervisor/kernels/vmlinux") . " 2>/dev/null | head -1")) : false;

$fc_bin = is_file('/usr/local/bin/firecracker');
$fc_version = $fc_bin ? trim(shell_exec('firecracker --version 2>&1 | head -1')) : false;
$fc_kernel = is_file("$kernelDir/firecracker/kernels/vmlinux");
$fc_kernel_size = $fc_kernel ? round(filesize("$kernelDir/firecracker/kernels/vmlinux") / 1048576) . ' MB' : false;
$fc_kernel_ver = $fc_kernel ? trim(shell_exec("grep -aoP 'Linux version \\K[\\d.]+' " . escapeshellarg("$kernelDir/firecracker/kernels/vmlinux") . " 2>/dev/null | head -1")) : false;

$kvm_available = is_readable('/dev/kvm');
$thinpool_name = 'microvms-thinpool';
$thinpool_exists = file_exists("/dev/mapper/{$thinpool_name}");

// VM Manager (libvirt) status
$libvirt_running = !empty(trim(shell_exec('pgrep -x libvirtd 2>/dev/null')));
$libvirt_version = $libvirt_running ? trim(shell_exec("virsh version --daemon 2>/dev/null | grep -oP 'libvirt \\K[\\d.]+'| head -1")) : false;
$qemu_version = $libvirt_running ? trim(shell_exec("virsh version 2>/dev/null | grep -oP 'QEMU \\K[\\d.]+'| tail -1")) : false;
$domain_cfg = @parse_ini_file('/boot/config/domain.cfg') ?: [];
$vm_manager_enabled = ($domain_cfg['SERVICE'] ?? '') === 'enable';

// Overall readiness
$issues = [];
if (!$flintlockd_bin) $issues[] = "flintlockd not installed";
if ($flintlockd_bin && !$flintlockd_running) $issues[] = "flintlockd not running";
if (!$containerd_bin) $issues[] = "flintlock-containerd not installed";
if ($containerd_bin && !$containerd_running) $issues[] = "flintlock-containerd not running";
if (!$kvm_available) $issues[] = "/dev/kvm not available";
if (!$ch_kernel && !$fc_kernel) $issues[] = "No kernel images downloaded";

$is_ready = empty($issues);
$status_class = $is_ready ? 'color:#4CAF50' : 'color:#f44336';
$status_text = $is_ready ? 'Ready' : 'Not Ready';
