<script>
var plugin = '<?=$plugin?>';

function done() {
  location = '/Settings';
}

function viewLog(service) {
  var logMap = {
    'microvms-containerd': '/var/log/microvms/containerd.log',
    'crane-registry': '/var/log/microvms/registry.log',
    'flintlockd': '/var/log/microvms/flintlockd.log'
  };
  var logFile = logMap[service] || '';
  var title = service + ' log';
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'view_log', logfile: logFile}, function(data) {
    if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
    if (data.success) {
      swal({
        title: title,
        text: '<pre style="text-align:left;max-height:400px;overflow:auto;font-size:11px;white-space:pre-wrap;word-break:break-all;background:#1a1a2e;padding:12px;border-radius:4px;color:#ccc;">' + (data.log || '(empty)') + '</pre>',
        html: true,
        confirmButtonText: 'Close'
      });
    } else {
      swal({title: 'Error', text: data.error || 'Failed to read log', type: 'error'});
    }
  });
}

function downloadKernel(engine) {
  swal({
    title: 'Download ' + engine + ' kernel?',
    text: 'This will download the default kernel for ' + engine + '.',
    showCancelButton: true,
    confirmButtonText: 'Download',
    closeOnConfirm: false
  }, function(confirmed) {
    if (!confirmed) return;
    swal({title: 'Downloading...', text: 'Please wait, this may take 1-2 minutes.', showConfirmButton: false});
    $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {
      cmd: 'download_kernel',
      engine: engine
    }, function(data) {
      if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
      if (data && data.success) {
        swal({title: 'Success', text: engine + ' kernel downloaded.', type: 'success'}, function() {
          location.reload();
        });
      } else {
        swal({title: 'Error', text: (data && data.error) || 'Download failed.', type: 'error'});
      }
    }).fail(function() {
      swal({title: 'Error', text: 'Request failed. Check network.', type: 'error'});
    });
  });
}

function serviceAction(service, action) {
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'service_action', service: service, action: action}, function(data) {
    if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
    if (data && data.success) {
      location.reload();
    } else {
      swal({title: 'Error', text: (data && data.error) || 'Action failed.', type: 'error'});
    }
  }).fail(function() {
    swal({title: 'Error', text: 'Request failed.', type: 'error'});
  });
}

function updateDefaultVMM() {
  var chEnabled = $('select[name="CH_ENABLED"]').val() === 'yes';
  var fcEnabled = $('select[name="FC_ENABLED"]').val() === 'yes';
  var sel = $('#selectDefaultVMM');
  sel.empty();
  if (chEnabled) sel.append('<option value="cloud-hypervisor">Cloud Hypervisor</option>');
  if (fcEnabled) sel.append('<option value="firecracker">Firecracker</option>');
  if (!chEnabled && !fcEnabled) sel.append('<option value="">No VMM enabled</option>');
  sel.prop('disabled', (chEnabled && !fcEnabled) || (!chEnabled && fcEnabled));
}

$(function() {
  $('select[name="FLINTLOCKD"]').on('change', function() {
    if ($(this).val() === 'enable') {
      $('#liquidmetal-options').slideDown();
    } else {
      $('#liquidmetal-options').slideUp();
    }
  });
  updateDefaultVMM();
});
</script>
