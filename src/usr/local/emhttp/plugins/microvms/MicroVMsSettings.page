<?php
/* ─── Configuration ─────────────────────────────────────────────────────── */
$plugin = 'microvms';
$cfg_file = "/boot/config/plugins/{$plugin}/{$plugin}.cfg";
$defaults = [
  'ENABLE'                => 'disable',
  'VMDIR'                 => '/mnt/user/appdata/microvm',
  'BRIDGE'                => 'br0',
  'DEFAULT_VCPUS'         => '2',
  'DEFAULT_MEMORY'        => '512',
  'DEFAULT_VMM'           => 'cloud-hypervisor',
  'AUTOSTART'             => 'no',
  'THINPOOL_DATA_SIZE_GB' => '20',
  'FLINTLOCKD'            => 'disable',
  'FLINTLOCKD_GRPC_PORT'  => '9090',
  'FLINTLOCKD_EXTRA_FLAGS'=> '',
  'CRANE_REGISTRY_DIR'    => '/mnt/user/appdata/microvm/registry',
  'CH_ENABLED'            => 'yes',
  'FC_ENABLED'            => 'no',
  'CH_KERNEL_URL'         => '',
  'FC_KERNEL_URL'         => '',
];
$cfg = file_exists($cfg_file) ? parse_ini_file($cfg_file) : [];
$cfg = array_merge($defaults, $cfg);

/* ─── Service Status Checks ─────────────────────────────────────────────── */
// libvirtd
$libvirtd_running = trim(shell_exec("pgrep -x libvirtd >/dev/null 2>&1 && echo 1 || echo 0")) === '1';

// KVM module
$kvm_loaded = file_exists('/dev/kvm');

// microvms-thinpool
$thinpool_active = trim(shell_exec("dmsetup status microvms-thinpool 2>/dev/null | grep -q 'thin-pool' && echo 1 || echo 0")) === '1';

// microvms-containerd
$containerd_running = trim(shell_exec("pgrep -f 'containerd.*microvms' >/dev/null 2>&1 && echo 1 || echo 0")) === '1';
$containerd_version = trim(shell_exec("/usr/local/bin/microvms-containerd --version 2>/dev/null | awk '{print \$3}'"));
if (empty($containerd_version)) $containerd_version = 'unknown';

// crane registry
$registry_running = trim(shell_exec("pgrep -f 'crane.*registry' >/dev/null 2>&1 && echo 1 || echo 0")) === '1';

// flintlockd
$flintlockd_running = trim(shell_exec("pgrep -x flintlockd >/dev/null 2>&1 && echo 1 || echo 0")) === '1';
$flintlockd_version = trim(shell_exec("flintlockd --version 2>/dev/null | awk '{print \$2}'"));
if (empty($flintlockd_version)) $flintlockd_version = 'unknown';

// Cloud Hypervisor VMM
$ch_binary = file_exists('/usr/local/bin/cloud-hypervisor');
$ch_kernel = file_exists($cfg['VMDIR'] . '/kernels/vmlinux-ch');
$ch_version = $ch_binary ? trim(shell_exec("cloud-hypervisor --version 2>/dev/null | awk '{print \$2}'")) : '';
if (empty($ch_version)) $ch_version = 'not installed';

// Firecracker VMM
$fc_binary = file_exists('/usr/local/bin/firecracker');
$fc_kernel = file_exists($cfg['VMDIR'] . '/kernels/vmlinux-fc');
$fc_version = $fc_binary ? trim(shell_exec("firecracker --version 2>/dev/null | head -1 | awk '{print \$2}'")) : '';
if (empty($fc_version)) $fc_version = 'not installed';

// Available bridges
$bridges = glob('/sys/class/net/br*');
$bridge_names = array_map(function($b){ return basename($b); }, $bridges ?: []);
if (empty($bridge_names)) $bridge_names = ['br0'];

// Enabled state
$enabled = ($cfg['ENABLE'] === 'enable');
$flintlockd_enabled = ($cfg['FLINTLOCKD'] === 'enable');
$ch_enabled = ($cfg['CH_ENABLED'] === 'yes');
$fc_enabled = ($cfg['FC_ENABLED'] === 'yes');
?>

