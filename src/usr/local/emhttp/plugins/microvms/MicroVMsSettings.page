<!-- ─── JavaScript ──────────────────────────────────────────────────────── -->
<script>
function done() {
  location = '/Settings';
}

function viewLog(service) {
  $.post('/plugins/microvms/include/exec.php', {action: 'viewlog', service: service}, function(data) {
    swal({
      title: service + ' log',
      html: '<pre style="text-align:left;max-height:400px;overflow:auto;font-size:12px;white-space:pre-wrap;">' + $('<div/>').text(data).html() + '</pre>',
      width: '70%'
    });
  });
}

function downloadKernel(engine) {
  swal({
    title: 'Downloading ' + engine + ' kernel...',
    text: 'Please wait, this may take a minute.',
    allowOutsideClick: false,
    onOpen: function() { swal.showLoading(); }
  });
  $.post('/plugins/microvms/include/exec.php', {action: 'download_kernel', engine: engine}, function(data) {
    if (data && data.success) {
      swal({title: 'Success', text: engine + ' kernel downloaded successfully.', type: 'success'}).then(function() {
        location.reload();
      });
    } else {
      swal({title: 'Error', text: (data && data.error) || 'Download failed. Check system log.', type: 'error'});
    }
  }, 'json').fail(function() {
    swal({title: 'Error', text: 'Request failed. Check network and try again.', type: 'error'});
  });
}

function serviceAction(service, action) {
  $.post('/plugins/microvms/include/exec.php', {action: 'service', service: service, command: action}, function(data) {
    if (data && data.success) {
      location.reload();
    } else {
      swal({title: 'Error', text: (data && data.error) || 'Action failed.', type: 'error'});
    }
  }, 'json').fail(function() {
    swal({title: 'Error', text: 'Request failed.', type: 'error'});
  });
}

function updateDefaultVMM() {
  var chEnabled = $('select[name="CH_ENABLED"]').val() === 'yes';
  var fcEnabled = $('select[name="FC_ENABLED"]').val() === 'yes';
  var sel = $('#selectDefaultVMM');
  sel.empty();
  if (chEnabled) sel.append('<option value="cloud-hypervisor">Cloud Hypervisor</option>');
  if (fcEnabled) sel.append('<option value="firecracker">Firecracker</option>');
  if (!chEnabled && !fcEnabled) sel.append('<option value="">No VMM enabled</option>');
  sel.prop('disabled', (chEnabled && !fcEnabled) || (!chEnabled && fcEnabled));
}

$(function() {
  // Toggle Liquidmetal options visibility
  $('select[name="FLINTLOCKD"]').on('change', function() {
    if ($(this).val() === 'enable') {
      $('#liquidmetal-options').slideDown();
    } else {
      $('#liquidmetal-options').slideUp();
    }
  });
  // Initial VMM dropdown state
  updateDefaultVMM();
});
</script>
