  </tr>
  <tr>
    <td class="svc-dep">containerd</td>
    <td><?php if (!$enabled): ?><span class="svc-dot svc-dot-grey"></span>Disabled<?php else: ?><span class="svc-dot <?=$containerd_running?'svc-dot-green':'svc-dot-red'?>"></span><?=$containerd_running?'Running':'Stopped'?><?php endif; ?></td>
    <td><?=htmlspecialchars($containerd_version ?: '')?></td>
