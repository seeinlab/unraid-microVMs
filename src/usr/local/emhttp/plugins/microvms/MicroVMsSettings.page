    <td>v<?=htmlspecialchars($fc_version)?> | Kernel: <span class="kernel-status <?=$fc_kernel ? 'kernel-ok' : 'kernel-missing'?>"><?=$fc_kernel ? '✓ present' : '✗ missing'?></span></td>
    <td><?php if (!$fc_kernel): ?><button type="button" class="svc-action-btn" onclick="downloadKernel('firecracker')">Download Kernel</button><?php endif; ?></td>
