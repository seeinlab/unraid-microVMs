<script>
var plugin = '<?=$plugin?>';

function done() { location = '/Settings'; }

function viewLog(service) {
  var logFile = (service === 'flintlockd') ? '/var/log/flintlockd.log' : '/var/log/flintlock-containerd.log';
  var title = service === 'flintlockd' ? 'Flintlockd Log' : 'Containerd Log';
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'view_log', logfile: logFile}, function(data) {
    if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
    if (data.success) {
      var html = '<pre style="text-align:left;max-height:500px;overflow:auto;font-size:11px;background:#1a1a2e;padding:12px;border-radius:4px;color:#ccc;white-space:pre-wrap;word-break:break-all;">' + (data.log || '(empty)') + '</pre>';
      swal({title: title, text: html, html: true, confirmButtonText: 'Close'});
    } else {
      swal({title: 'Error', text: data.error || 'Failed to read log', type: 'error'});
    }
  });
}

function downloadKernel(engine) {
  var label = engine === 'cloud_hypervisor' ? 'Cloud Hypervisor' : 'Firecracker';
  var size = engine === 'cloud_hypervisor' ? '~60 MB' : '~37 MB';
  var html = '<div style="text-align:left;">';
  html += '<p>Download <b>' + label + '</b> kernel (' + size + ')?</p>';
  html += '<p style="font-size:0.85em;opacity:0.7;">Source: ' + (engine === 'cloud_hypervisor' ? 'github.com/cloud-hypervisor/linux' : 's3.amazonaws.com/spec.ccfc.min') + '</p>';
  html += '</div>';

  swal({
    title: 'Download Kernel',
    text: html,
    html: true,
    showCancelButton: true,
    confirmButtonText: 'Download',
    closeOnConfirm: false
  }, function(confirmed) {
    if (!confirmed) return;
    var logHtml = '<div id="dl-log" style="background:#1a1a2e;border:1px solid #333;border-radius:4px;padding:12px;font-family:monospace;font-size:12px;color:#0f0;text-align:left;max-height:300px;overflow-y:auto;min-height:120px;">';
    logHtml += '<div>Starting download...</div>';
    logHtml += '</div>';
    swal({title: label + ' Kernel', text: logHtml, html: true, showConfirmButton: false, showCancelButton: false});

    var log = document.getElementById('dl-log');
    function addLog(msg, color) {
      var line = document.createElement('div');
      line.style.color = color || '#0f0';
      line.textContent = msg;
      log.appendChild(line);
      log.scrollTop = log.scrollHeight;
    }

    addLog('$ mkdir -p /mnt/user/system/microvms/' + engine.replace('_','-') + '/kernels/');
    setTimeout(function() {
      addLog('$ curl -fsSL -o vmlinux <url>');
      addLog('Downloading... this may take 1-2 minutes');
      addLog('');

      $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {
        cmd: 'download_kernels',
        cloud_hypervisor: engine === 'cloud_hypervisor' ? '1' : '0',
        firecracker: engine === 'firecracker' ? '1' : '0'
      }, function(data) {
        if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
        if (data.success) {
          addLog('');
          addLog('✓ ' + data.message, '#4CAF50');
          addLog('');
          addLog('Done.', '#4CAF50');
          setTimeout(function() {
            var btn = document.createElement('button');
            btn.textContent = 'DONE';
            btn.style.cssText = 'margin-top:12px;padding:8px 24px;border:1px solid #f0a30a;background:transparent;color:#f0a30a;border-radius:3px;cursor:pointer;font-weight:bold;';
            btn.onclick = function() { location.reload(); };
            log.parentNode.appendChild(btn);
          }, 300);
        } else {
          addLog('');
          addLog('✗ ERROR: ' + (data.error || 'Download failed'), '#f44336');
          setTimeout(function() {
            var btn = document.createElement('button');
            btn.textContent = 'CLOSE';
            btn.style.cssText = 'margin-top:12px;padding:8px 24px;border:1px solid #f44336;background:transparent;color:#f44336;border-radius:3px;cursor:pointer;font-weight:bold;';
            btn.onclick = function() { swal.close(); };
            log.parentNode.appendChild(btn);
          }, 300);
        }
      }).fail(function() {
        addLog('✗ Request failed — check network', '#f44336');
      });
    }, 500);
  });
}
</script>
