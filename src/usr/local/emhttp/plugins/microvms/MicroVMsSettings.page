      <?php else: ?>
      <span class="svc-dot <?=$thinpool_active ? 'svc-dot-green' : 'svc-dot-red'?>"></span>
      <?=$thinpool_active ? 'Active' : 'Inactive'?>
      <?php endif; ?>
    </td>
    <td><?=$cfg['THINPOOL_DATA_SIZE_GB']?>GB thin provisioned pool</td>
    <td></td>
  </tr>
  <!-- microvms-containerd -->
  <tr>
    <td class="svc-dep">microvms-containerd</td>
    <td>
      <?php if (!$enabled): ?>
      <span class="svc-dot svc-dot-grey"></span>Disabled
      <?php else: ?>
      <span class="svc-dot <?=$containerd_running ? 'svc-dot-green' : 'svc-dot-red'?>"></span>
      <?=$containerd_running ? 'Running' : 'Stopped'?>
      <?php endif; ?>
    </td>
    <td>v<?=htmlspecialchars($containerd_version)?></td>
    <td>
      <?php if ($enabled): ?>
