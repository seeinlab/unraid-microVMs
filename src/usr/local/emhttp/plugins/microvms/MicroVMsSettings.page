      <?=$registry_running ? 'Running' : 'Stopped'?>
      <?php endif; ?>
    </td>
    <td>OCI image registry</td>
    <td>
      <?php if ($enabled): ?>
      <button type="button" class="svc-action-btn" onclick="viewLog('crane-registry')">View Log</button>
      <?php endif; ?>
    </td>
  </tr>
  <!-- flintlockd -->
  <tr>
    <td class="svc-dep">flintlockd</td>
    <td>
      <?php if (!$enabled): ?>
      <span class="svc-dot svc-dot-grey"></span>Disabled
      <?php else: ?>
      <span class="svc-dot <?=$flintlockd_running ? 'svc-dot-green' : 'svc-dot-red'?>"></span>
      <?=$flintlockd_running ? 'Running' : 'Stopped'?>
      <?php endif; ?>
    </td>
    <td>v<?=htmlspecialchars($flintlockd_version)?> | gRPC :<?=htmlspecialchars($cfg['FLINTLOCKD_GRPC_PORT'])?></td>
    <td>
      <?php if ($enabled): ?>
