$plugin = "microvms";
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/$plugin/include/common.php";
$cfg = microvm_load_config();
// Get available namespaces for dropdowns
$sock = '/var/run/microvms/containerd.sock';
$nsOptions = '';
if (file_exists($sock)) {
    $nsList = array_filter(explode("\n", trim(shell_exec("ctr -a $sock namespaces list -q 2>/dev/null"))));
    foreach ($nsList as $ns) {
        $ns = trim($ns);
        if (empty($ns) || $ns === 'flintlock') continue;
        $nsOptions .= "<option value=\"$ns\">$ns</option>";
    }
}
if (empty($nsOptions)) $nsOptions = '<option value="default">default</option><option value="ch">ch</option><option value="fc">fc</option>';
?>

