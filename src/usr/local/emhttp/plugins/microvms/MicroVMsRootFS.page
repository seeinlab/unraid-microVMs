<?php
$plugin = "microvms";
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/$plugin/include/common.php";

$cfg = microvm_load_config();
$vmdir = $cfg['VMDIR'] ?? '/mnt/user/microvms';
$sock = '/var/run/microvms/containerd.sock';

// Check containerd socket exists
$containerd_running = file_exists($sock);

// Pulled images
$ch_images = [];
$fc_images = [];
if ($containerd_running) {
    $ch_out = shell_exec("ctr -a $sock -n cloud-hypervisor images list -q 2>/dev/null");
    if ($ch_out) $ch_images = array_filter(explode("\n", trim($ch_out)));

    $fc_out = shell_exec("ctr -a $sock -n firecracker images list -q 2>/dev/null");
    if ($fc_out) $fc_images = array_filter(explode("\n", trim($fc_out)));
}

// Active snapshots
$ch_snapshots = [];
$fc_snapshots = [];
if ($containerd_running) {
    $ch_snap_out = shell_exec("ctr -a $sock -n cloud-hypervisor snapshots --snapshotter devmapper list 2>/dev/null");
    if ($ch_snap_out) {
        $lines = array_filter(explode("\n", trim($ch_snap_out)));
        // First line is header, skip it
        if (count($lines) > 1) {
            array_shift($lines);
            $ch_snapshots = $lines;
        }
    }

    $fc_snap_out = shell_exec("ctr -a $sock -n firecracker snapshots --snapshotter devmapper list 2>/dev/null");
    if ($fc_snap_out) {
        $lines = array_filter(explode("\n", trim($fc_snap_out)));
        if (count($lines) > 1) {
            array_shift($lines);
            $fc_snapshots = $lines;
        }
    }
}

// Existing rootfs images (legacy raw storage)
$images = [];
if (is_dir($vmdir)) {
    foreach (glob("$vmdir/*/rootfs.{raw,ext4}", GLOB_BRACE) as $f) {
        $name_vm = basename(dirname($f));
        $size = filesize($f);
        $images[] = ['name' => $name_vm, 'path' => $f, 'size' => $size];
    }
}
?>

<?php if (!$containerd_running): ?>
<div class="notice" style="padding:10px; margin-bottom:15px; border:1px solid #ff9800; background:#2e2a1a; border-radius:4px;">
  <i class="fa fa-warning" style="color:#ff9800;"></i> containerd is not running. Start it from the Settings → Services tab.
</div>
<?php endif; ?>

<!-- Pulled Images Section -->
<table class="tablesorter shift ups">
<thead><tr><td colspan="3"><b>Pulled Images (containerd)</b>
  <span style="float:right;"><input type="button" value="Prune Unused" onclick="pruneImages()" class="vm-btn" style="font-size:0.8em;"></span>
</td></tr></thead>
</table>

<table class="tablesorter shift ups">
<thead><tr>
  <th>Namespace</th>
  <th>Image Reference</th>
</tr></thead>
<tbody>
<?php if (empty($ch_images) && empty($fc_images)): ?>
  <tr><td colspan="2" style="text-align:center;padding:15px;opacity:0.6;">No pulled images found in containerd.</td></tr>
<?php else: ?>
  <?php foreach ($ch_images as $img): ?>
  <tr>
    <td><span style="color:#4CAF50;"><i class="fa fa-cloud"></i> cloud-hypervisor</span></td>
    <td style="font-family:monospace;font-size:0.85em;"><?=htmlspecialchars($img)?></td>
  </tr>
  <?php endforeach; ?>
  <?php foreach ($fc_images as $img): ?>
  <tr>
    <td><span style="color:#ff9800;"><i class="fa fa-fire"></i> firecracker</span></td>
    <td style="font-family:monospace;font-size:0.85em;"><?=htmlspecialchars($img)?></td>
  </tr>
  <?php endforeach; ?>
<?php endif; ?>
</tbody>
</table>

<br>

<!-- Active Snapshots Section -->
<table class="tablesorter shift ups">
<thead><tr><td colspan="4"><b>Active Snapshots (devmapper)</b></td></tr></thead>
</table>

<table class="tablesorter shift ups">
<thead><tr>
  <th>Namespace</th>
  <th>Key</th>
  <th>Parent</th>
  <th>Kind</th>
</tr></thead>
<tbody>
<?php if (empty($ch_snapshots) && empty($fc_snapshots)): ?>
  <tr><td colspan="4" style="text-align:center;padding:15px;opacity:0.6;">No active snapshots.</td></tr>
<?php else: ?>
  <?php foreach ($ch_snapshots as $line):
    // Parse snapshot line: KEY PARENT KIND
    $parts = preg_split('/\s+/', trim($line), 4);
    $key = $parts[0] ?? '';
    $parent = $parts[1] ?? '';
    $kind = $parts[2] ?? '';
  ?>
  <tr>
    <td><span style="color:#4CAF50;"><i class="fa fa-cloud"></i> cloud-hypervisor</span></td>
    <td style="font-family:monospace;font-size:0.85em;"><?=htmlspecialchars($key)?></td>
    <td style="font-family:monospace;font-size:0.85em;"><?=htmlspecialchars($parent)?></td>
    <td><?=htmlspecialchars($kind)?></td>
  </tr>
  <?php endforeach; ?>
  <?php foreach ($fc_snapshots as $line):
    $parts = preg_split('/\s+/', trim($line), 4);
    $key = $parts[0] ?? '';
    $parent = $parts[1] ?? '';
    $kind = $parts[2] ?? '';
  ?>
  <tr>
    <td><span style="color:#ff9800;"><i class="fa fa-fire"></i> firecracker</span></td>
    <td style="font-family:monospace;font-size:0.85em;"><?=htmlspecialchars($key)?></td>
    <td style="font-family:monospace;font-size:0.85em;"><?=htmlspecialchars($parent)?></td>
    <td><?=htmlspecialchars($kind)?></td>
  </tr>
  <?php endforeach; ?>
<?php endif; ?>
</tbody>
</table>

<br>

<!-- Existing rootFS Images (raw storage) -->
<table class="tablesorter shift ups">
<thead><tr><td colspan="4"><b>Raw rootFS Images</b></td></tr></thead>
</table>

<table class="tablesorter shift ups">
<thead><tr>
  <th>VM Name</th>
  <th>Path</th>
  <th>Size</th>
  <th>Actions</th>
</tr></thead>
<tbody>
<?php if (empty($images)): ?>
  <tr><td colspan="4" style="text-align:center;padding:15px;opacity:0.6;">No raw rootfs images found.</td></tr>
<?php else: ?>
  <?php foreach ($images as $img): ?>
  <tr>
    <td><b><?=htmlspecialchars($img['name'])?></b></td>
    <td style="font-family:monospace;font-size:0.85em;"><?=htmlspecialchars($img['path'])?></td>
    <td><?=number_format($img['size'] / 1048576, 0)?> MB</td>
    <td><button class="vm-btn" onclick="deleteRootfs('<?=htmlspecialchars($img['name'])?>', '<?=htmlspecialchars($img['path'])?>')">DELETE</button></td>
  </tr>
  <?php endforeach; ?>
<?php endif; ?>
</tbody>
</table>

<br>

<!-- Kernel Images -->
<table class="tablesorter shift ups">
<thead><tr><td colspan="3"><b>Kernel Images</b></td></tr></thead>
</table>

<table class="tablesorter shift ups">
<thead><tr><th>Engine</th><th>File</th><th>Size</th></tr></thead>
<tbody>
<?php
$systemDir = '/mnt/user/system/microvms';
$found = false;
foreach (['cloud-hypervisor', 'firecracker'] as $engine) {
    $kpath = "$systemDir/$engine/kernels/vmlinux";
    if (is_file($kpath)) {
        $found = true;
        $engineLabel = ($engine === 'cloud-hypervisor') ? 'Cloud Hypervisor' : 'Firecracker';
        echo "<tr><td>{$engineLabel}</td><td style='font-family:monospace;'>{$kpath}</td><td>".number_format(filesize($kpath)/1048576,0)." MB</td></tr>";
    }
}
// Also check legacy path
foreach (['cloud-hypervisor', 'firecracker'] as $engine) {
    $kpath = "$vmdir/kernels/$engine/vmlinux";
    if (is_file($kpath)) {
        $found = true;
        $engineLabel = ($engine === 'cloud-hypervisor') ? 'Cloud Hypervisor' : 'Firecracker';
        echo "<tr><td>{$engineLabel}</td><td style='font-family:monospace;'>{$kpath}</td><td>".number_format(filesize($kpath)/1048576,0)." MB</td></tr>";
    }
}
if (!$found) echo "<tr><td colspan='3' style='text-align:center;opacity:0.6;'>No kernels found</td></tr>";
?>
</tbody>
</table>

<div id="pruneOutput" style="display:none; margin-top:15px; padding:12px; background:#111; color:#0f0; font-family:monospace; font-size:12px; max-height:200px; overflow-y:auto; border-radius:4px;"></div>

<style>
.vm-btn { padding:4px 14px; margin:2px; cursor:pointer; border:1px solid #555; border-radius:3px; background:#333; color:#ddd; text-transform:uppercase; font-size:0.85em; }
.vm-btn:hover { background:#555; }
</style>

<script>
var plugin = '<?=$plugin?>';

function pruneImages() {
  swal({
    title: 'Prune Unused Images?',
    text: 'This will remove all unreferenced images from containerd in both namespaces.',
    type: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Prune',
    cancelButtonText: 'Cancel',
    closeOnConfirm: false
  }, function(confirmed) {
    if (confirmed) {
      $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'prune_images'}, function(data) {
        if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
        if (data.success) {
          swal({title: 'Done', text: data.message || 'Prune complete', type: 'success'}, function() { location.reload(); });
        } else {
          swal({title: 'Error', text: data.error || 'Prune failed', type: 'error'});
        }
      }).fail(function() {
        swal({title: 'Error', text: 'Request failed', type: 'error'});
      });
    }
  });
}

function deleteRootfs(name, path) {
  swal({
    title: 'Delete rootFS?',
    text: 'Delete rootfs image for "' + name + '"?\n\nPath: ' + path + '\n\nNote: If the VM is running, it must be stopped first. The VM config will be kept.',
    type: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Delete',
    cancelButtonText: 'Cancel',
    closeOnConfirm: false
  }, function(confirmed) {
    if (confirmed) {
      $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'delete_rootfs', name: name}, function(data) {
        if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
        if (data.success) {
          swal({title: 'Deleted', text: data.message, type: 'success'}, function() { location.reload(); });
        } else {
          swal({title: 'Cannot Delete', text: data.error || 'Delete failed', type: 'error'});
        }
      });
    }
  });
}
</script>
