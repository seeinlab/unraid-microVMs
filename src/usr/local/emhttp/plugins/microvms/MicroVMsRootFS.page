<script>
var plugin = 'microvms';
var storageData = null;

$(function() {
  refreshStorage();
});

function refreshStorage() {
  $('#volumes-body').html('<tr><td colspan="8" class="section-loading"><i class="fa fa-spinner fa-spin"></i> Loading...</td></tr>');
  $('#images-body').html('<tr><td colspan="5" class="section-loading"><i class="fa fa-spinner fa-spin"></i> Loading...</td></tr>');

  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'storage_info'}, function(resp) {
    if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) {}
    if (!resp.success) {
      showNotice(resp.error || 'Failed to load storage info');
      return;
    }
    storageData = resp.data;
    renderPool(storageData.thin_pool);
    renderVolumes(storageData.volumes);
    renderImages(storageData.images);
  }).fail(function() {
    showNotice('AJAX request failed. Is the backend reachable?');
  });
}

function showNotice(msg) {
  $('#storage-notice-text').text(msg);
  $('#storage-notice').show();
}

function hideNotice() {
  $('#storage-notice').hide();
}

// --- Thin Pool ---
function renderPool(pool) {
  if (!pool || pool.status === 'inactive') {
    $('#pool-data-text').text('Inactive');
    $('#pool-meta-text').text('—');
    $('#pool-device').html('<span class="pool-inactive">Not Active</span>');
    $('#pool-status-label').text('Thin pool is not initialized');
    return;
  }
  // Data
  var dataPct = pool.data_percent || 0;
  $('#pool-data-text').text(formatSize(pool.data_used_mb) + ' / ' + formatSize(pool.data_total_mb));
  $('#pool-data-bar').css('width', dataPct + '%').attr('class', 'pool-bar-fill ' + barColor(dataPct));
  $('#pool-data-pct').text(dataPct + '%');

  // Meta
  var metaPct = pool.meta_total_mb > 0 ? Math.round(pool.meta_used_mb / pool.meta_total_mb * 100 * 10) / 10 : 0;
  $('#pool-meta-text').text(pool.meta_used_mb.toFixed(2) + ' MB / ' + pool.meta_total_mb.toFixed(2) + ' MB');
  $('#pool-meta-bar').css('width', metaPct + '%').attr('class', 'pool-bar-fill ' + barColor(metaPct));
  $('#pool-meta-pct').text(metaPct + '%');

  // Device
  $('#pool-device').text('/dev/mapper/' + pool.device);
  $('#pool-status-label').html('<span style="color:#4CAF50;">● Active</span>');
}

function barColor(pct) {
  if (pct >= 90) return 'red';
  if (pct >= 70) return 'yellow';
  return 'green';
}

function formatSize(mb) {
  if (mb >= 1024) return (mb / 1024).toFixed(1) + ' GB';
  return mb.toFixed(1) + ' MB';
}

// --- Volumes ---
function renderVolumes(volumes) {
  if (!volumes || volumes.length === 0) {
    $('#volumes-body').html('<tr><td colspan="8" style="text-align:center;padding:15px;opacity:0.6;">No volumes found.</td></tr>');
    return;
  }
  var html = '';
  volumes.forEach(function(v) {
    var typeBadge = v.type === 'thin'
      ? '<span class="badge badge-thin">thin</span>'
      : '<span class="badge badge-raw">raw</span>';
    var statusBadge = v.status === 'active'
      ? '<span class="badge badge-active">active</span>'
      : '<span class="badge badge-available">available</span>';
    var usedBy = v.used_by && v.used_by !== 'unused'
      ? '<span class="tag-vm">' + escHtml(v.used_by) + '</span>'
      : '<span class="tag-unused">unused</span>';
    var sizeStr = v.size_mb > 0 ? formatSize(v.size_mb) : '—';
    var canRemove = false;
    if (v.type === 'raw' && (!v.used_by || v.used_by === 'unused')) {
      canRemove = true;
    } else if (v.type === 'thin' && (!v.used_by || v.used_by === 'unused')) {
      canRemove = true;
    }
    var actions = '';
    if (v.type === 'thin' && v.status === 'active') {
      actions += '<input type="button" onclick="downloadRootfs(\'' + escAttr(v.used_by || v.name) + '\', \'' + escAttr(v.namespace) + '\')" value="Download .raw">';
    }
    if (canRemove) {
      actions += ' <input type="button" onclick="removeVolume(\'' + escAttr(v.name) + '\', \'' + escAttr(v.namespace) + '\', \'' + escAttr(v.type) + '\')" value="Remove">';
    }

    html += '<tr>'
      + '<td class="mono">' + escHtml(v.name) + '</td>'
      + '<td><i class="fa fa-cube" style="color:#58a6ff;"></i> ' + escHtml(v.namespace) + '</td>'
      + '<td>' + typeBadge + '</td>'
      + '<td>' + sizeStr + '</td>'
      + '<td class="mono">' + escHtml(v.device) + '</td>'
      + '<td>' + statusBadge + '</td>'
      + '<td>' + usedBy + '</td>'
      + '<td>' + actions + '</td>'
      + '</tr>';
  });
  $('#volumes-body').html(html);
}

// --- Images ---
function renderImages(images) {
  if (!images || images.length === 0) {
    $('#images-body').html('<tr><td colspan="5" style="text-align:center;padding:15px;opacity:0.6;">No images found in containerd.</td></tr>');
    return;
  }
  var html = '';
  images.forEach(function(img) {
    var usedBy = '';
    if (img.used_by && img.used_by.length > 0) {
      usedBy = img.used_by.map(function(n) { return '<span class="tag-vm">' + escHtml(n) + '</span>'; }).join(' ');
    } else {
      usedBy = '<span class="tag-unused">unused</span>';
    }
    var sizeStr = img.size_mb > 0 ? formatSize(img.size_mb) : '—';
    var canRemove = !img.used_by || img.used_by.length === 0;
    var actions = canRemove
      ? '<input type="button" onclick="removeImage(\'' + escAttr(img.ref) + '\', \'' + escAttr(img.namespace) + '\')" value="Remove">'
      : '';

    html += '<tr>'
      + '<td class="mono">' + escHtml(img.ref) + '</td>'
      + '<td><i class="fa fa-cube" style="color:#58a6ff;"></i> ' + escHtml(img.namespace) + '</td>'
      + '<td>' + sizeStr + '</td>'
      + '<td>' + usedBy + '</td>'
      + '<td>' + actions + '</td>'
      + '</tr>';
  });
  $('#images-body').html(html);
}

// --- Actions ---
function pullImage() {
  swal({
    title: 'Pull Image',
    html: true,
    text: '<div style="text-align:left;">'
      + '<label style="display:block;margin-bottom:4px;font-size:0.85em;">Image Reference:</label>'
      + '<input id="swal-pull-ref" class="swal2-input" placeholder="e.g. nginx:alpine, ubuntu:22.04" style="width:100%;margin-bottom:12px;padding:8px;background:#222;border:1px solid #555;color:#ddd;border-radius:3px;font-family:monospace;">'
      + '<label style="display:block;margin-bottom:4px;font-size:0.85em;">Namespace:</label>'
      + '<select id="swal-pull-ns" style="width:100%;padding:8px;background:#222;border:1px solid #555;color:#ddd;border-radius:3px;">'
      + '<?=$nsOptions?>'
      + '</select>'
      + '</div>',
    showCancelButton: true,
    confirmButtonText: 'Pull',
    cancelButtonText: 'Cancel',
    closeOnConfirm: false
  }, function(confirmed) {
    if (!confirmed) return;
    var ref = document.getElementById('swal-pull-ref').value.trim();
    var ns = document.getElementById('swal-pull-ns').value;
    if (!ref) {
      swal.showInputError('Please enter an image reference');
      return false;
    }
    swal({title: 'Pulling...', text: 'Pulling ' + ref + ' into namespace "' + ns + '"...', type: 'info', showConfirmButton: false, showCancelButton: false});
    $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'pull_image', image: ref, namespace: ns}, function(resp) {
      if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) {}
      if (resp.success) {
        swal({title: 'Success', text: resp.message || 'Image pulled successfully', type: 'success'}, function() { refreshStorage(); });
      } else {
        swal({title: 'Error', text: resp.error || 'Pull failed', type: 'error'});
      }
    }).fail(function() {
      swal({title: 'Error', text: 'Request failed', type: 'error'});
    });
  });
}

function runGC() {
  swal({
    title: 'Run Garbage Collection',
    html: true,
    text: '<div style="text-align:left;">'
      + '<label style="display:block;margin-bottom:4px;font-size:0.85em;">Namespace:</label>'
      + '<select id="swal-gc-ns" style="width:100%;padding:8px;background:#222;border:1px solid #555;color:#ddd;border-radius:3px;">'
      + '<option value="all">All namespaces</option>'
      + '<?=$nsOptions?>'
      + '</select>'
      + '<p style="margin-top:10px;font-size:0.85em;opacity:0.7;">Removes images not used by any VM, then triggers containerd garbage collection to clean orphaned snapshots and layers.</p>'
      + '</div>',
    showCancelButton: true,
    confirmButtonText: 'Run GC',
    cancelButtonText: 'Cancel',
    closeOnConfirm: false
  }, function(confirmed) {
    if (!confirmed) return;
    var ns = document.getElementById('swal-gc-ns').value;
    swal({title: 'Running...', text: 'Removing unused images and running GC...', type: 'info', showConfirmButton: false});
    $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'run_gc', namespace: ns}, function(resp) {
      if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) {}
      if (resp.success) {
        swal({title: 'Done', text: resp.message || 'GC complete', type: 'success'}, function() { refreshStorage(); });
      } else {
        swal({title: 'Error', text: resp.error || 'GC failed', type: 'error'});
      }
    }).fail(function() {
      swal({title: 'Error', text: 'Request failed', type: 'error'});
    });
  });
}

function removeVolume(name, ns, type) {
  swal({
    title: 'Remove Volume?',
    text: 'Remove volume "' + name + '" from namespace "' + ns + '"?\n\nType: ' + type + '\nThis action cannot be undone.',
    type: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Remove',
    cancelButtonText: 'Cancel',
    closeOnConfirm: false
  }, function(confirmed) {
    if (!confirmed) return;
    $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'remove_volume', name: name, namespace: ns, type: type}, function(resp) {
      if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) {}
      if (resp.success) {
        swal({title: 'Removed', text: resp.message || 'Volume removed', type: 'success'}, function() { refreshStorage(); });
      } else {
        swal({title: 'Error', text: resp.error || 'Remove failed', type: 'error'});
      }
    }).fail(function() {
      swal({title: 'Error', text: 'Request failed', type: 'error'});
    });
  });
}

function removeImage(ref, ns) {
  swal({
    title: 'Remove Image?',
    text: 'Remove image:\n' + ref + '\n\nFrom namespace "' + ns + '"?\nThis action cannot be undone.',
    type: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Remove',
    cancelButtonText: 'Cancel',
    closeOnConfirm: false
  }, function(confirmed) {
    if (!confirmed) return;
    $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'remove_image', namespace: ns, image: ref}, function(resp) {
      if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) {}
      if (resp.success) {
        swal({title: 'Removed', text: resp.message || 'Image removed', type: 'success'}, function() { refreshStorage(); });
      } else {
        swal({title: 'Error', text: resp.error || 'Remove failed', type: 'error'});
      }
    }).fail(function() {
      swal({title: 'Error', text: 'Request failed', type: 'error'});
    });
  });
}

// --- Pull & Convert to rootfs ---
function pullAndConvert() {
  swal({
    title: 'Pull & Convert to rootfs',
    html: true,
    text: '<div style="text-align:left;">'
      + '<label style="display:block;margin-bottom:4px;font-size:0.85em;">Namespace:</label>'
      + '<select id="swal-conv-ns" onchange="loadNsImages()" style="width:100%;padding:8px;background:#222;border:1px solid #555;color:#ddd;border-radius:3px;margin-bottom:12px;">'
      + '<?=$nsOptions?>'
      + '</select>'
      + '<label style="display:block;margin-bottom:4px;font-size:0.85em;">Image (select existing or enter new):</label>'
      + '<select id="swal-conv-existing" onchange="if(this.value)document.getElementById(\'swal-conv-ref\').value=this.value" style="width:100%;padding:8px;background:#222;border:1px solid #555;color:#ddd;border-radius:3px;margin-bottom:6px;">'
      + '<option value="">-- Pull new image --</option>'
      + '</select>'
      + '<input id="swal-conv-ref" class="swal2-input" placeholder="e.g. nginx:alpine, ubuntu:22.04" style="width:100%;padding:8px;background:#222;border:1px solid #555;color:#ddd;border-radius:3px;font-family:monospace;margin-bottom:12px;">'
      + '<label style="display:block;margin-bottom:4px;font-size:0.85em;">Volume Name (for the rootfs):</label>'
      + '<input id="swal-conv-name" class="swal2-input" placeholder="e.g. my-nginx" style="width:100%;padding:8px;background:#222;border:1px solid #555;color:#ddd;border-radius:3px;font-family:monospace;margin-bottom:12px;">'
      + '<label style="display:block;margin-bottom:4px;font-size:0.85em;">Storage Type:</label>'
      + '<select id="swal-conv-type" style="width:100%;padding:8px;background:#222;border:1px solid #555;color:#ddd;border-radius:3px;">'
      + '<option value="thin">Thin (devmapper snapshot — shared layers, copy-on-write)</option>'
      + '<option value="raw">Raw (rootfs.raw file — standalone, portable)</option>'
      + '</select>'
      + '<p style="margin-top:10px;font-size:0.8em;opacity:0.6;">Select an existing image or enter a new ref to pull.<br>Thin: devmapper snapshot (fast). Raw: ext4 image file (portable).</p>'
      + '</div>',
    showCancelButton: true,
    confirmButtonText: 'Pull & Convert',
    cancelButtonText: 'Cancel',
    closeOnConfirm: false
  }, function(confirmed) {
    if (!confirmed) return;
    var ref = document.getElementById('swal-conv-ref').value.trim();
    var ns = document.getElementById('swal-conv-ns').value;
    var volName = document.getElementById('swal-conv-name').value.trim();
    var storageType = document.getElementById('swal-conv-type').value;
    if (!ref) { swal.showInputError('Please enter an image reference'); return false; }
    if (!volName) { swal.showInputError('Please enter a volume name'); return false; }
    swal({title: 'Converting...', text: 'Pulling ' + ref + ' and creating ' + storageType + ' rootfs volume...', type: 'info', showConfirmButton: false});
    $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'pull_rootfs', image: ref, namespace: ns, name: volName, storage_type: storageType}, function(resp) {
      if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) {}
      if (resp.success) {
        swal({title: 'Success', text: resp.message || 'rootfs volume created', type: 'success'}, function() { refreshStorage(); });
      } else {
        swal({title: 'Error', text: resp.error || 'Conversion failed', type: 'error'});
      }
    }).fail(function() { swal({title: 'Error', text: 'Request failed', type: 'error'}); });
  });
  // Load images for initial namespace
  setTimeout(loadNsImages, 200);
}

function loadNsImages() {
  var ns = document.getElementById('swal-conv-ns');
  if (!ns) return;
  var sel = document.getElementById('swal-conv-existing');
  if (!sel) return;
  sel.innerHTML = '<option value="">-- loading... --</option>';
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'storage_info'}, function(resp) {
    if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) {}
    var html = '<option value="">-- Pull new image --</option>';
    if (resp.success && resp.data && resp.data.images) {
      resp.data.images.forEach(function(img) {
        if (img.namespace === ns.value) {
          html += '<option value="' + escAttr(img.ref) + '">' + escHtml(img.ref) + '</option>';
        }
      });
    }
    sel.innerHTML = html;
  });
}

// --- Download rootfs.raw ---
function downloadRootfs(name, ns) {
  swal({
    title: 'Download rootfs.raw',
    text: 'Export thin volume "' + name + '" to a .raw file?\n\nThis copies the block device to $VMDIR/' + ns + '/' + name + '/rootfs.raw\nThe file can then be downloaded or used with raw storage mode.',
    type: 'info',
    showCancelButton: true,
    confirmButtonText: 'Export',
    cancelButtonText: 'Cancel',
    closeOnConfirm: false
  }, function(confirmed) {
    if (!confirmed) return;
    swal({title: 'Exporting...', text: 'Copying block device to raw file...', type: 'info', showConfirmButton: false});
    $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'export_rootfs', name: name, namespace: ns}, function(resp) {
      if (typeof resp === 'string') try { resp = JSON.parse(resp); } catch(e) {}
      if (resp.success) {
        swal({title: 'Exported', text: resp.message || 'rootfs.raw created', type: 'success'}, function() { refreshStorage(); });
      } else {
        swal({title: 'Error', text: resp.error || 'Export failed', type: 'error'});
      }
    }).fail(function() { swal({title: 'Error', text: 'Request failed', type: 'error'}); });
  });
}

// --- Helpers ---
function escHtml(s) {
  var el = document.createElement('span');
  el.textContent = s || '';
  return el.innerHTML;
}

function escAttr(s) {
  return (s || '').replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/"/g, '&quot;');
}
</script>
