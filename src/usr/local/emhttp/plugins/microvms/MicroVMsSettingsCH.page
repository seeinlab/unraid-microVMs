Menu="MicroVMsSettings:2"
Title="Cloud Hypervisor"
Tag="cloud"
---
<?php
$plugin = 'microvms';
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/$plugin/include/common.php";

$cfg = microvm_load_config();
$kernelDir = '/mnt/user/system/microvms';
$ch_binary = is_file('/usr/local/bin/cloud-hypervisor');
$ch_kernel = is_file("$kernelDir/cloud-hypervisor/kernels/vmlinux");
$ch_version = $ch_binary ? trim(shell_exec('cloud-hypervisor --version 2>/dev/null')) : '';
$ch_kernel_ver = $ch_kernel ? trim(shell_exec("grep -aoP 'Linux version \\K[\\d.]+' " . escapeshellarg("$kernelDir/cloud-hypervisor/kernels/vmlinux") . " 2>/dev/null | head -1")) : '';
$ch_enabled = ($cfg['CH_ENABLED'] ?? 'yes') === 'yes';
?>
<style>
.mvm-btn { padding:5px 14px; font-size:0.85em; cursor:pointer; border-radius:3px; border:1px solid rgba(128,128,128,0.4); background:transparent; margin-right:6px; margin-top:8px; }
.mvm-btn:hover { background:rgba(128,128,128,0.1); }
</style>

<form markdown="1" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="#file" value="<?=$plugin?>/<?=$plugin?>.controlplane.cfg">
<input type="hidden" name="#command" value="/etc/rc.d/rc.microvms restart">

_(Enable Cloud Hypervisor)_:
: <select name="CH_ENABLED" size="1">
  <?=mk_option($cfg['CH_ENABLED'] ?? 'yes', "yes", "Yes")?>
  <?=mk_option($cfg['CH_ENABLED'] ?? 'yes', "no", "No")?>
  </select>

_(Kernel URL)_:
: <input type="text" name="CH_KERNEL_URL" value="<?=htmlspecialchars($cfg['CH_KERNEL_URL'] ?? '')?>" placeholder="Leave blank for default" style="width:70%;">

> Custom URL for the Cloud Hypervisor PVH kernel. Leave blank to use the built-in default.

&nbsp;
: <span class="inline-block"><input type="submit" value="_(Apply)_"><input type="button" value="_(Done)_" onclick="done()"></span>
</form>

<script>
var plugin = '<?=$plugin?>';
function done() { location = '/Settings/MicroVMsSettings'; }
function downloadKernel(engine) {
  swal({title:'Download '+engine+' kernel?',showCancelButton:true,confirmButtonText:'Download',closeOnConfirm:false},function(ok){
    if(!ok)return;
    swal({title:'Downloading...',text:'Please wait...',showConfirmButton:false});
    $.post('/plugins/'+plugin+'/backend/MicroVMAdmin.php',{cmd:'download_kernel',engine:engine},function(data){
      if(typeof data==='string')try{data=JSON.parse(data);}catch(e){}
      if(data&&data.success)swal({title:'Done',text:data.message,type:'success'},function(){location.reload();});
      else swal({title:'Error',text:(data&&data.error)||'Failed',type:'error'});
    }).fail(function(){swal({title:'Error',text:'Request failed',type:'error'});});
  });
}
</script>
