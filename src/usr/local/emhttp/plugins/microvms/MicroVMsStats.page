<tbody>
<?php
$services = [
    'containerd' => ['bin' => 'microvms-containerd', 'label' => 'containerd'],
    'flintlockd' => ['bin' => 'flintlockd', 'label' => 'flintlockd'],
    'crane' => ['bin' => 'crane', 'label' => 'crane (registry)'],
];
$sysUptime = floatval(explode(' ', file_get_contents('/proc/uptime'))[0]);
foreach ($services as $key => $svc) {
    $pid = trim(shell_exec("pidof {$svc['bin']} 2>/dev/null"));
    $status = $pid ? '<span style="color:#4CAF50;">● Running</span>' : '<span style="color:#f44336;">● Stopped</span>';
    $upStr = '-';
    if ($pid) {
        $stat = @file_get_contents("/proc/$pid/stat");
        if ($stat) {
            $parts = preg_split('/\)\s+/', $stat, 2);
            if (isset($parts[1])) {
                $fields = explode(' ', $parts[1]);
                $starttime = intval($fields[19] ?? 0);
                $elapsed = round($sysUptime - ($starttime / 100));
                if ($elapsed >= 86400) $upStr = floor($elapsed/86400) . 'd ' . floor(($elapsed%86400)/3600) . 'h';
                elseif ($elapsed >= 3600) $upStr = floor($elapsed/3600) . 'h ' . floor(($elapsed%3600)/60) . 'm';
                elseif ($elapsed >= 60) $upStr = floor($elapsed/60) . 'm';
                else $upStr = $elapsed . 's';
            }
        }
    }
    echo "<tr><td><b>{$svc['label']}</b></td><td style='font-family:monospace;'>" . ($pid ?: '-') . "</td><td>$status</td><td>$upStr</td></tr>\n";
}
?>
</tbody>
</table>

<script>
var plugin = '<?=$plugin?>';
var hostMem = <?=$host_mem?>;

function formatUptime(s) {
  if (s < 60) return s + 's';
  if (s < 3600) return Math.floor(s/60) + 'm';
  var h = Math.floor(s/3600), m = Math.floor((s%3600)/60);
  if (h < 24) return h + 'h ' + m + 'm';
  var d = Math.floor(h/24); h = h % 24;
  return d + 'd ' + h + 'h';
}

function makeBar(percent, label) {
  var p = Math.min(percent, 100);
  return '<span>' + label + '</span><div class="usage-disk mm"><span style="width:' + p + '%"> </span><span></span></div>';
}

function refreshStats() {
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'vm_stats'}, function(data) {
    if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
    if (!data || !data.success) return;
    var stats = data.stats || [];

    if (stats.length === 0) {
      $('#vm-usage-body').html('<tr><td colspan="7" style="text-align:center;opacity:0.5;">No running VMs</td></tr>');
      $('#vm-proc-body').html('<tr><td colspan="3" style="text-align:center;opacity:0.5;">No running VMs</td></tr>');
      return;
    }

    var usageHtml = '';
    var procHtml = '';

    for (var i = 0; i < stats.length; i++) {
      var s = stats[i];
      // Guest CPU (allocated vCPUs)
      var guestCpu = s.vcpus || '-';
      // Host CPU (usage bar)
      var hostCpuBar = makeBar(s.cpu_percent, s.cpu_percent + '%');
      // Memory: inuse(RSS) / current(allocated) / maximum
      var memStr = s.rss_mb + 'M / ' + s.mem_current + 'M / ' + s.mem_max + 'M';
      var memPercent = s.mem_max > 0 ? (s.rss_mb / s.mem_max * 100) : 0;
      var memBar = makeBar(memPercent, memStr);
      // Disk IO
      var diskStr = 'R: ' + s.disk_read_mb + 'M W: ' + s.disk_write_mb + 'M';
      // Network IO
      var netStr = 'RX: ' + s.net_rx_mb + 'M TX: ' + s.net_tx_mb + 'M';

      usageHtml += '<tr>'
        + '<td><b>' + s.name + '</b></td>'
        + '<td>' + guestCpu + '</td>'
        + '<td>' + hostCpuBar + '</td>'
        + '<td>' + memBar + '</td>'
        + '<td>' + diskStr + '</td>'
        + '<td>' + netStr + '</td>'
        + '<td>' + formatUptime(s.uptime) + '</td>'
        + '</tr>';

      var vmmDisplay = (s.vmm === 'cloud-hypervisor') ? 'Cloud Hypervisor' : 'Firecracker';
      procHtml += '<tr>'
        + '<td><b>' + s.name + '</b></td>'
        + '<td>' + vmmDisplay + '</td>'
        + '<td style="font-family:monospace;">' + s.pid + '</td>'
        + '</tr>';
    }

    $('#vm-usage-body').html(usageHtml);
    $('#vm-proc-body').html(procHtml);
  });
}

$(function() {
  refreshStats();
  setInterval(refreshStats, 3000);
});
</script>
