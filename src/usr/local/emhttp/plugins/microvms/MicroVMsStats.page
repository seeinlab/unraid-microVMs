Menu="MicroVMs:3"
Title="Usage Statistics"
Tag="bar-chart"
Cond="is_file('/usr/local/bin/flintlockd')"
Markdown="false"
---
<?php
$plugin = "microvms";
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/$plugin/include/common.php";

$cfg = microvm_load_config();
$vmdir = $cfg['VMDIR'] ?? '/mnt/user/microvms';
$vms = microvm_list_vms();

// Gather stats
$total_vms = count($vms);
$running_vms_list = array_filter($vms, fn($v) => $v['state'] === 'running');
$running_count = count($running_vms_list);
$stopped_vms = $total_vms - $running_count;

$total_cpus_allocated = 0;
$total_mem_allocated = 0;

foreach ($running_vms_list as $vm) {
    $total_cpus_allocated += $vm['config']['vcpus'] ?? $vm['config']['boot_vcpus'] ?? 0;
    $total_mem_allocated += $vm['config']['memory_mb'] ?? 0;
}

// Host info
$host_cpus = intval(trim(shell_exec('nproc')));
$host_mem = intval(trim(shell_exec("free -m | awk '/^Mem:/{print \$2}'")));

// Build PID map for running VMs (accurate: pidof + cmdline)
$vm_pids = [];
foreach (['cloud-hypervisor', 'firecracker'] as $bin) {
    $pids = trim(shell_exec("pidof $bin 2>/dev/null"));
    if (!$pids) continue;
    foreach (explode(' ', $pids) as $pid) {
        $cmdline = @file_get_contents("/proc/$pid/cmdline");
        if ($cmdline && preg_match('/microvms-([a-z0-9\-]+)\.sock/', $cmdline, $m)) {
            $vm_pids[$m[1]] = intval($pid);
        }
        // flintlockd VMs: extract name from state dir path
        if ($cmdline && preg_match('/flintlockd-state\/vm\/[^\/]+\/([a-z0-9\-]+)\//', $cmdline, $m)) {
            $vm_pids[$m[1]] = intval($pid);
        }
    }
}

// Get process stats from /proc/PID/
function get_vm_proc_stats($pid) {
    if (!$pid || !file_exists("/proc/$pid/status")) return null;
    $stats = [];

    // Memory (VmRSS from /proc/PID/status)
    $status = @file_get_contents("/proc/$pid/status");
    if ($status && preg_match('/VmRSS:\s+(\d+)\s+kB/', $status, $m)) {
        $stats['rss_mb'] = round($m[1] / 1024);
    }

    // CPU time from /proc/PID/stat (field 14=utime, 15=stime in clock ticks)
    $stat = @file_get_contents("/proc/$pid/stat");
    if ($stat) {
        // Skip past the comm field (may contain spaces/parens)
        $parts = preg_split('/\)\s+/', $stat, 2);
        if (isset($parts[1])) {
            $fields = explode(' ', $parts[1]);
            $utime = intval($fields[11] ?? 0); // field 14 (0-indexed from after comm)
            $stime = intval($fields[12] ?? 0); // field 15
            $clk_tck = 100; // standard on Linux
            $stats['cpu_seconds'] = round(($utime + $stime) / $clk_tck);
            // Uptime for this process (field 22 = starttime)
            $starttime = intval($fields[19] ?? 0);
            $uptime = floatval(explode(' ', @file_get_contents('/proc/uptime'))[0]);
            $stats['uptime_seconds'] = round($uptime - ($starttime / $clk_tck));
            if ($stats['uptime_seconds'] > 0) {
                $stats['cpu_percent'] = round(($stats['cpu_seconds'] / $stats['uptime_seconds']) * 100, 1);
            }
        }
    }

    // Disk I/O from /proc/PID/io
    $io = @file_get_contents("/proc/$pid/io");
    if ($io) {
        if (preg_match('/read_bytes:\s+(\d+)/', $io, $m)) $stats['read_mb'] = round($m[1] / 1048576, 1);
        if (preg_match('/write_bytes:\s+(\d+)/', $io, $m)) $stats['write_mb'] = round($m[1] / 1048576, 1);
    }

    return $stats;
}

// Storage
$vmdir_size = trim(shell_exec("du -sh " . escapeshellarg($vmdir) . " 2>/dev/null | cut -f1")) ?: '0';
?>

<style>
.stat-grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap:15px; margin:15px 0; }
.stat-card { background:#1e1e2e; border:1px solid #333; border-radius:8px; padding:15px; text-align:center; }
.stat-card .number { font-size:2em; font-weight:bold; color:#89b4fa; }
.stat-card .label { font-size:0.85em; opacity:0.7; margin-top:5px; }
.stat-card.running .number { color:#4CAF50; }
.stat-card.stopped .number { color:#f44336; }
</style>

<table class="tablesorter shift ups">
<thead><tr><td>Overview</td></tr></thead>
</table>

<div class="stat-grid">
  <div class="stat-card"><div class="number"><?=$total_vms?></div><div class="label">Total microVMs</div></div>
  <div class="stat-card running"><div class="number"><?=$running_count?></div><div class="label">Running</div></div>
  <div class="stat-card stopped"><div class="number"><?=$stopped_vms?></div><div class="label">Stopped</div></div>
  <div class="stat-card"><div class="number"><?=$total_cpus_allocated?>/<?=$host_cpus?></div><div class="label">vCPUs Allocated</div></div>
  <div class="stat-card"><div class="number"><?=$total_mem_allocated?>M/<?=$host_mem?>M</div><div class="label">Memory Allocated</div></div>
  <div class="stat-card"><div class="number"><?=$vmdir_size?></div><div class="label">Disk Used</div></div>
</div>

<?php if ($running_count > 0): ?>
<table class="tablesorter shift ups">
<thead><tr><td>Running VM Details</td></tr></thead>
</table>

<table class="tablesorter shift ups">
<thead><tr><th>Name</th><th>vCPUs</th><th>Memory</th><th>IP</th><th>PID</th><th>CPU %</th><th>RSS</th><th>Disk Read</th><th>Disk Write</th></tr></thead>
<tbody>
<?php foreach ($vms as $vm): if ($vm['state'] !== 'running') continue;
    $network = microvm_get_network($vm['config']);
    $ip = $network['ip'] ?? '-';
    $vcpus = $vm['config']['vcpus'] ?? $vm['config']['boot_vcpus'] ?? '-';
    $mem = $vm['config']['memory_mb'] ?? '-';
    $pid = $vm_pids[$vm['name']] ?? 0;
    $proc = $pid ? get_vm_proc_stats($pid) : null;
?>
  <tr>
    <td><b><?=htmlspecialchars($vm['name'])?></b></td>
    <td><?=$vcpus?></td>
    <td><?=$mem?> MB</td>
    <td><?=htmlspecialchars($ip)?></td>
    <td style="font-family:monospace;"><?=$pid ?: '-'?></td>
    <td><?=$proc ? $proc['cpu_percent'] . '%' : '-'?></td>
    <td><?=$proc ? $proc['rss_mb'] . ' MB' : '-'?></td>
    <td><?=$proc ? $proc['read_mb'] . ' MB' : '-'?></td>
    <td><?=$proc ? $proc['write_mb'] . ' MB' : '-'?></td>
  </tr>
<?php endforeach; ?>
</tbody>
</table>
<?php endif; ?>
