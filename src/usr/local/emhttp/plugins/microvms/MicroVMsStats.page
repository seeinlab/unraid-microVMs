Menu="MicroVMs:3"
Title="Usage Statistics"
Tag="bar-chart"
Markdown="false"
---
<?php
$plugin = "microvms";
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/$plugin/include/common.php";

$cfg = microvm_load_config();
$vms = microvm_list_vms();
$total_vms = count($vms);
$running_count = count(array_filter($vms, fn($v) => $v['state'] === 'running'));
$stopped_count = $total_vms - $running_count;
$host_cpus = intval(trim(shell_exec('nproc')));
$host_mem = intval(trim(shell_exec("free -m | awk '/^Mem:/{print \$2}'")));
?>

<style>
.stat-grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap:12px; margin:15px 0; }
.stat-card { background:#1e1e2e; border:1px solid #333; border-radius:8px; padding:12px; text-align:center; }
.stat-card .number { font-size:1.8em; font-weight:bold; color:#89b4fa; }
.stat-card .label { font-size:0.8em; opacity:0.7; margin-top:4px; }
.stat-card.running .number { color:#4CAF50; }
.stat-card.stopped .number { color:#f44336; }
#stats-table td, #process-table td { font-family:monospace; font-size:0.85rem; }
.loading { opacity:0.5; }
</style>

<table class="tablesorter shift ups">
<thead><tr><td>Overview</td></tr></thead>
</table>

<div class="stat-grid">
  <div class="stat-card"><div class="number"><?=$total_vms?></div><div class="label">Total microVMs</div></div>
  <div class="stat-card running"><div class="number"><?=$running_count?></div><div class="label">Running</div></div>
  <div class="stat-card stopped"><div class="number"><?=$stopped_count?></div><div class="label">Stopped</div></div>
  <div class="stat-card"><div class="number"><?=$host_cpus?></div><div class="label">Host vCPUs</div></div>
  <div class="stat-card"><div class="number"><?=$host_mem?>M</div><div class="label">Host RAM</div></div>
</div>

<!-- Live Resource Usage (AJAX polled) -->
<table class="tablesorter shift ups">
<thead><tr><td>Live Resource Usage <span id="stats-status" style="font-size:0.7em;opacity:0.5;margin-left:10px;"></span></td></tr></thead>
</table>

<table class="tablesorter shift ups" id="stats-table">
<thead><tr>
  <th>Name</th>
  <th>CPU %</th>
  <th>RSS</th>
  <th>Disk Read</th>
  <th>Disk Write</th>
  <th>Net RX</th>
  <th>Net TX</th>
</tr></thead>
<tbody>
  <tr><td colspan="7" style="text-align:center;opacity:0.5;">Loading...</td></tr>
</tbody>
</table>

<!-- VMM Processes -->
<table class="tablesorter shift ups">
<thead><tr><td>VMM Processes</td></tr></thead>
</table>

<table class="tablesorter shift ups" id="process-table">
<thead><tr>
  <th>Name</th>
  <th>VMM</th>
  <th>PID</th>
  <th>TAP</th>
  <th>Uptime</th>
</tr></thead>
<tbody>
  <tr><td colspan="5" style="text-align:center;opacity:0.5;">Loading...</td></tr>
</tbody>
</table>

<script>
var plugin = '<?=$plugin?>';

function formatUptime(seconds) {
  if (seconds < 60) return seconds + 's';
  if (seconds < 3600) return Math.floor(seconds/60) + 'm ' + (seconds%60) + 's';
  var h = Math.floor(seconds/3600);
  var m = Math.floor((seconds%3600)/60);
  return h + 'h ' + m + 'm';
}

function refreshStats() {
  $('#stats-status').text('updating...');
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'vm_stats'}, function(data) {
    if (typeof data === 'string') try { data = JSON.parse(data); } catch(e) {}
    if (!data || !data.success) return;

    var stats = data.stats || [];
    var statsHtml = '';
    var procHtml = '';

    if (stats.length === 0) {
      statsHtml = '<tr><td colspan="7" style="text-align:center;opacity:0.5;">No running VMs</td></tr>';
      procHtml = '<tr><td colspan="5" style="text-align:center;opacity:0.5;">No running VMs</td></tr>';
    } else {
      for (var i = 0; i < stats.length; i++) {
        var s = stats[i];
        statsHtml += '<tr>'
          + '<td><b>' + s.name + '</b></td>'
          + '<td>' + s.cpu_percent + '%</td>'
          + '<td>' + s.rss_mb + ' MB</td>'
          + '<td>' + s.disk_read_mb + ' MB</td>'
          + '<td>' + s.disk_write_mb + ' MB</td>'
          + '<td>' + s.net_rx_mb + ' MB</td>'
          + '<td>' + s.net_tx_mb + ' MB</td>'
          + '</tr>';

        var vmmDisplay = (s.vmm === 'cloud-hypervisor') ? 'Cloud Hypervisor' : 'Firecracker';
        procHtml += '<tr>'
          + '<td><b>' + s.name + '</b></td>'
          + '<td>' + vmmDisplay + '</td>'
          + '<td>' + s.pid + '</td>'
          + '<td>' + (s.tap || '-') + '</td>'
          + '<td>' + formatUptime(s.uptime) + '</td>'
          + '</tr>';
      }
    }

    $('#stats-table tbody').html(statsHtml);
    $('#process-table tbody').html(procHtml);
    $('#stats-status').text('updated ' + new Date().toLocaleTimeString());
  });
}

$(function() {
  refreshStats();
  setInterval(refreshStats, 3000);
});
</script>
