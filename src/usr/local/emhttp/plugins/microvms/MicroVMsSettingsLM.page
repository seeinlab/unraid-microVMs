<?php
$plugin = 'microvms';
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/$plugin/include/common.php";

$cfg = microvm_load_config();
$flintlockd_enabled = ($cfg['FLINTLOCKD'] ?? 'disable') === 'enable';
$flintlockd_running = !empty(trim(shell_exec('pidof flintlockd 2>/dev/null')));
$flintlockd_version = trim(shell_exec('flintlockd version 2>/dev/null'));
$registry_running = !empty(trim(shell_exec('pidof crane 2>/dev/null')));
?>

<script>
var plugin = '<?=$plugin?>';
function done() { location = '/Settings/MicroVMsSettings'; }
function viewLog(service) {
  $.post('/plugins/'+plugin+'/backend/MicroVMAdmin.php',{cmd:'view_log',service:service},function(data){
    if (typeof data==='string') try{data=JSON.parse(data);}catch(e){}
    if (data && data.success) swal({title:service,text:'<pre style="text-align:left;max-height:400px;overflow:auto;font-size:11px;white-space:pre-wrap;word-break:break-all;background:#1a1a2e;padding:12px;border-radius:4px;color:#ccc;">'+(data.log||'(empty)')+'</pre>',html:true,confirmButtonText:'Close'});
    else swal({title:'Error',text:(data&&data.error)||'Failed',type:'error'});
  });
}
function serviceAction(service,action) {
  $.post('/plugins/'+plugin+'/backend/MicroVMAdmin.php',{cmd:'service_action',service:service,action:action},function(data){
    if(typeof data==='string')try{data=JSON.parse(data);}catch(e){}
    if(data&&data.success)location.reload();
    else swal({title:'Error',text:(data&&data.error)||'Failed',type:'error'});
  });
}
</script>

<?php if ($flintlockd_enabled): ?>
<div style="margin-bottom:16px;">
<b>Flintlockd:</b>
<?php if ($flintlockd_running): ?>
<input type="button" value="Stop" onclick="serviceAction('flintlockd','stop')">
<input type="button" value="Restart" onclick="serviceAction('flintlockd','restart')">
<?php else: ?>
<input type="button" value="Start" onclick="serviceAction('flintlockd','start')">
<?php endif; ?>
<input type="button" value="View Log" onclick="viewLog('flintlockd')">
&nbsp;&nbsp;
<b>Registry:</b>
<?php if ($registry_running): ?>
<input type="button" value="Stop" onclick="serviceAction('registry','stop')">
<input type="button" value="Restart" onclick="serviceAction('registry','restart')">
<?php else: ?>
<input type="button" value="Start" onclick="serviceAction('registry','start')">
<?php endif; ?>
<input type="button" value="View Log" onclick="viewLog('registry')">
</div>
<?php endif; ?>

<form markdown="1" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="#file" value="<?=$plugin?>/<?=$plugin?>.controlplane.cfg">
<input type="hidden" name="#command" value="/etc/rc.d/rc.microvms restart">

_(Enable Liquidmetal)_:
: <select name="FLINTLOCKD" size="1">
  <?=mk_option($cfg['FLINTLOCKD'] ?? 'disable', "enable", "Yes")?>
  <?=mk_option($cfg['FLINTLOCKD'] ?? 'disable', "disable", "No")?>
  </select>

<?php if ($flintlockd_enabled): ?>

_(Crane Registry Storage)_:
: <input type="text" name="CRANE_REGISTRY_DIR" value="<?=htmlspecialchars($cfg['CRANE_REGISTRY_DIR'] ?? '/mnt/user/system/microvms/crane/registry')?>" data-pickfolders="true" data-pickfilter="NO_FILES_FILTER" data-pickroot="/mnt">

<?php
$flintlockd_defaults = '--grpc-endpoint 0.0.0.0:9090 --containerd-socket /var/run/microvms/containerd.sock --bridge-name br0 --parent-iface br0 --cloudhypervisor-bin /usr/local/bin/cloud-hypervisor --firecracker-bin /usr/local/bin/firecracker --state-dir /var/run/microvms/flintlockd-state --log-output /var/log/microvms/flintlockd.log --insecure --default-provider cloudhypervisor --verbosity 0';
$flintlockd_flags = $cfg['FLINTLOCKD_FLAGS'] ?? $flintlockd_defaults;
?>
_(Flintlockd Flags)_:
: <textarea name="FLINTLOCKD_FLAGS" rows="4" cols="80" style="font-family:monospace; font-size:0.85em;"><?=htmlspecialchars($flintlockd_flags)?></textarea>

> All flags passed to `flintlockd run`. Clear and Apply to reset to defaults.

<?php endif; ?>

&nbsp;
: <span class="inline-block"><input type="submit" value="_(Apply)_"><input type="button" value="_(Done)_" onclick="done()"></span>
</form>
