Menu="OtherSettings"
Icon="microvm.manager.png"
Title="microVM Manager"
Tag="microchip"
---
<?php
$plugin = "microvm.manager";
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/$plugin/include/common.php";

$cfg = microvm_load_config();

$ch_bin = is_file('/usr/local/bin/cloud-hypervisor');
$ch_version = $ch_bin ? trim(shell_exec('cloud-hypervisor --version 2>/dev/null')) : false;
$remote_bin = is_file('/usr/local/bin/ch-remote');
$remote_version = $remote_bin ? trim(shell_exec('ch-remote --version 2>/dev/null')) : false;
$fc_bin = is_file('/usr/local/bin/firecracker');
$fc_version = $fc_bin ? trim(shell_exec('firecracker --version 2>&1 | head -1')) : false;
$crane_bin = is_file('/usr/local/bin/crane');
$crane_version = $crane_bin ? trim(shell_exec('crane version 2>/dev/null')) : false;
$kvm_available = is_readable('/dev/kvm');

$vmdir = $cfg['VMDIR'] ?? '/mnt/user/microvms';
$vmdir_exists = is_dir($vmdir);
$kernel_exists = is_file("$vmdir/kernels/cloud-hypervisor/vmlinux") || is_file("$vmdir/kernels/firecracker/vmlinux");

// Count VMs
$vm_count = 0;
if ($vmdir_exists) {
    foreach (glob("$vmdir/*/config.json") as $f) $vm_count++;
}

// Determine status
$issues = [];
if (!$ch_bin && !$fc_bin) $issues[] = "No VM engine installed (need cloud-hypervisor or firecracker)";
if (!$kvm_available) $issues[] = "/dev/kvm not accessible";
if (!$vmdir_exists) $issues[] = "VM storage directory not found: $vmdir";
if (!$kernel_exists) $issues[] = "Kernel not found: $vmdir/kernels/vmlinux";

$is_ready = empty($issues);
$status_text = $is_ready ? '<span style="color:#4CAF50;"><b>Ready</b></span>' : '<span style="color:#f44336;"><b>Failed</b></span>';
$ch_status = $ch_bin ? '<span style="color:#4CAF50;">✓</span>' : '<span style="color:#f44336;">✗</span>';
$fc_status = $fc_bin ? '<span style="color:#4CAF50;">✓</span>' : '<span style="color:#f44336;">✗</span>';
$crane_status = $crane_bin ? '<span style="color:#4CAF50;">✓</span>' : '<span style="opacity:0.5;">—</span>';
?>

<div class="title"><span class="left"><i class="title fa fa-fire"></i>_(Status)_</span><span class="right">Status: <?=$status_text?></span></div>

<form markdown="1" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="#file" value="microvm.manager/microvm.manager.cfg">

<?php if (!$is_ready): ?>
<?php foreach ($issues as $issue): ?>
> <span style="color:#f44336;">✗ <?=$issue?></span>

<?php endforeach; ?>
<?php endif; ?>

_(Cloud Hypervisor)_:
: <?=$ch_version ?: '<span style="color:#f44336;">Not installed</span>'?><?=$remote_version ? " + $remote_version" : ''?> <?=$ch_status?>

_(Firecracker)_:
: <?=$fc_version ?: '<span style="opacity:0.5;">Not installed</span>'?> <?=$fc_status?>

_(OCI Image Tool)_:
: crane <?=$crane_version ?: '<span style="opacity:0.5;">Not installed (optional)</span>'?> <?=$crane_status?>

_(KVM)_:
: <?=$kvm_available ? '/dev/kvm available <span style="color:#4CAF50;">✓</span>' : '<span style="color:#f44336;">✗ Not available</span>'?>

_(Kernel)_:
: <?php
$ch_kernel = is_file("$vmdir/kernels/cloud-hypervisor/vmlinux");
$fc_kernel = is_file("$vmdir/kernels/firecracker/vmlinux");
if ($ch_kernel) echo "kernels/cloud-hypervisor/vmlinux <span style='color:#4CAF50;'>✓</span><br>";
if ($fc_kernel) echo "kernels/firecracker/vmlinux <span style='color:#4CAF50;'>✓</span>";
if (!$ch_kernel && !$fc_kernel) echo '<span style="color:#f44336;">✗ No kernels found</span>';
?>

<div class="title"><span class="left"><i class="title fa fa-gears"></i>_(General Settings)_</span></div>

_(Enable microVM Manager)_:
: <select name="SERVICE">
  <?=mk_option($cfg['SERVICE'] ?? 'disable', 'disable', _('No'))?>
  <?=mk_option($cfg['SERVICE'] ?? 'disable', 'enable', _('Yes'))?>
  </select>

_(VM Storage Location)_:
: <input type="text" name="VMDIR" value="<?=htmlspecialchars($cfg['VMDIR'] ?? '/mnt/user/microvms')?>" data-pickroot="/mnt" data-pickfolders="true" data-pickcloseonfile="true">

_(Default Engine)_:
: <select name="DEFAULT_ENGINE">
  <?=mk_option($cfg['DEFAULT_ENGINE'] ?? 'cloud-hypervisor', 'cloud-hypervisor', _('Cloud Hypervisor'))?>
  <?=mk_option($cfg['DEFAULT_ENGINE'] ?? 'cloud-hypervisor', 'firecracker', _('Firecracker'))?>
  </select>

_(Network Bridge)_:
: <select name="BRIDGE">
  <?php foreach(glob('/sys/class/net/br*') as $br): $name=basename($br); ?>
  <?=mk_option($cfg['BRIDGE'] ?? 'br0', $name, $name)?>
  <?php endforeach; ?>
  </select>

_(Default vCPUs)_:
: <input type="number" name="DEFAULT_CPUS" min="1" max="<?=exec('nproc')?>" value="<?=htmlspecialchars($cfg['DEFAULT_CPUS'] ?? '1')?>">

_(Default Memory)_ (MB):
: <input type="number" name="DEFAULT_MEMORY" min="64" step="64" value="<?=htmlspecialchars($cfg['DEFAULT_MEMORY'] ?? '256')?>">

_(Autostart VMs on array start)_:
: <select name="AUTOSTART">
  <?=mk_option($cfg['AUTOSTART'] ?? 'no', 'no', _('No'))?>
  <?=mk_option($cfg['AUTOSTART'] ?? 'no', 'yes', _('Yes'))?>
  </select>

&nbsp;
: <span class="inline-block"><input type="submit" name="#apply" value="_(Apply)_"><input type="button" value="_(Done)_" onclick="done()"></span>

</form>

<script>
function done() { location = '/Settings'; }
</script>
