Menu="OtherSettings"
Icon="microvm.manager.png"
Title="microVM Manager"
Tag="microchip"
---
<?php
$plugin = "microvm.manager";
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/$plugin/include/common.php";

$cfg = microvm_load_config();

$ch_version = trim(shell_exec('cloud-hypervisor --version 2>/dev/null') ?: 'Not installed');
$remote_version = trim(shell_exec('ch-remote --version 2>/dev/null') ?: 'Not installed');
$crane_version = trim(shell_exec('crane version 2>/dev/null') ?: 'Not installed');

exec("/etc/rc.d/rc.microvm status 2>/dev/null", $status_output);
$is_running = (strpos(implode(' ', $status_output), 'running') !== false);

$vm_count = 0;
$vmdir = $cfg['VMDIR'] ?? '/mnt/user/microvms';
if (is_dir($vmdir)) {
    foreach (glob("$vmdir/*/config.json") as $f) $vm_count++;
}
?>

<div class="title"><span class="left"><i class="title fa fa-fire"></i>_(Service Status)_</span><span class="right"><?=$is_running ? '<span style="color:#4CAF50;">Status: <b>Running</b></span>' : '<span style="color:#f44336;">Status: <b>Stopped</b></span>'?></span></div>

<form markdown="1" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="#file" value="microvm.manager/microvm.manager.cfg">
<input type="hidden" name="#command" value="/plugins/microvm.manager/restart.sh">

_(Cloud Hypervisor)_:
: <?=$ch_version?>

_(ch-remote)_:
: <?=$remote_version?>

_(crane)_:
: <?=$crane_version?>

_(Configured VMs)_:
: <?=$vm_count?>

<div class="title"><span class="left"><i class="title fa fa-gears"></i>_(General Settings)_</span></div>

_(Enable microVM Manager)_:
: <select name="SERVICE">
  <?=mk_option($cfg['SERVICE'] ?? 'disable', 'disable', _('No'))?>
  <?=mk_option($cfg['SERVICE'] ?? 'disable', 'enable', _('Yes'))?>
  </select>

_(VM Storage Location)_:
: <input type="text" name="VMDIR" value="<?=htmlspecialchars($cfg['VMDIR'] ?? '/mnt/user/microvms')?>" data-pickroot="/mnt" data-pickfolders="true" data-pickcloseonfile="true">

_(Network Bridge)_:
: <select name="BRIDGE">
  <?php foreach(glob('/sys/class/net/br*') as $br): $name=basename($br); ?>
  <?=mk_option($cfg['BRIDGE'] ?? 'br0', $name, $name)?>
  <?php endforeach; ?>
  </select>

_(Default vCPUs)_:
: <input type="number" name="DEFAULT_CPUS" min="1" max="<?=exec('nproc')?>" value="<?=htmlspecialchars($cfg['DEFAULT_CPUS'] ?? '1')?>">

_(Default Memory)_ (MB):
: <input type="number" name="DEFAULT_MEMORY" min="64" step="64" value="<?=htmlspecialchars($cfg['DEFAULT_MEMORY'] ?? '256')?>">

_(Autostart VMs on array start)_:
: <select name="AUTOSTART">
  <?=mk_option($cfg['AUTOSTART'] ?? 'no', 'no', _('No'))?>
  <?=mk_option($cfg['AUTOSTART'] ?? 'no', 'yes', _('Yes'))?>
  </select>

&nbsp;
: <span class="inline-block"><input type="submit" name="#apply" value="_(Apply)_"><input type="button" value="_(Done)_" onclick="done()"></span>

</form>

<div class="title"><span class="left"><i class="title fa fa-power-off"></i>_(Service Control)_</span></div>

&nbsp;
: <span class="inline-block"><input type="button" id="btnStart" value="_(Start)_" onclick="serviceCmd('start')" <?=$is_running ? 'disabled' : ''?>><input type="button" id="btnStop" value="_(Stop)_" onclick="serviceCmd('stop')" <?=$is_running ? '' : 'disabled'?>><input type="button" id="btnRestart" value="_(Restart)_" onclick="serviceCmd('restart')"></span><span id="svcStatus" style="margin-left:15px;"></span>

<script>
function done() { location = '/Settings'; }
function serviceCmd(action) {
  $('#svcStatus').html('<i class="fa fa-spinner fa-spin"></i> ' + action + '...');
  $('#btnStart,#btnStop,#btnRestart').prop('disabled', true);
  $.post('/plugins/microvm.manager/backend/MicroVMAdmin.php', {cmd: 'service', action: action}, function(data) {
    var msg = (typeof data === 'object') ? (data.message || JSON.stringify(data)) : data;
    $('#svcStatus').html('<span style="color:#4CAF50;">Done</span>');
    setTimeout(function(){ location.reload(); }, 2000);
  }).fail(function() {
    $('#svcStatus').html('<span style="color:#f44336;">Failed</span>');
    setTimeout(function(){ location.reload(); }, 2000);
  });
}
</script>
