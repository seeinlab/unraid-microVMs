<?php
$plugin = "microvm.manager";
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/$plugin/include/common.php";

$cfg = microvm_load_config();
$noticeMessage = null;

if (($var['fsState'] ?? '') != "Started") {
    $noticeMessage = "Array must be <b>started</b> to manage MicroVMs";
} elseif (($cfg['SERVICE'] ?? 'disable') !== 'enable') {
    $noticeMessage = "microVM Manager is disabled. <a href='/Settings/MicroVMSettings'>Enable in Settings</a>";
}
?>
<?php if ($noticeMessage): ?>
<p class="notice"><?=$noticeMessage?></p>
<?php endif; ?>
