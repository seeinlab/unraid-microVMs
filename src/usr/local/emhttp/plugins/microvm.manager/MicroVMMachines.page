  <?php foreach ($vms as $vm):
    $name = htmlspecialchars($vm['name']);
    $state = $vm['state'];
    $cpus = $vm['config']['boot_vcpus'] ?? '-';
    $mem_mb = $vm['config']['memory_mb'] ?? '-';
    $mem_display = ($mem_mb !== '-' && $mem_mb >= 1024) ? round($mem_mb / 1024, 1) . ' GB' : $mem_mb . ' MB';
    $ip = htmlspecialchars($vm['config']['ip'] ?? '-');
    $engine = $vm['config']['engine'] ?? 'cloud-hypervisor';
    $engine_display = ($engine === 'cloud-hypervisor') ? 'Cloud Hypervisor' : 'Firecracker';
    $icon = "/plugins/microvm.manager/images/{$engine}.png";
    $tap = 'tap-' . $vm['name'];
    $bridge_name = $vm['config']['bridge'] ?? $cfg['BRIDGE'] ?? 'br0';
    $tap_display = $tap . '@' . $bridge_name;
    $autostart = !empty($vm['config']['autostart']);

    $status_class = ($state === 'running') ? 'started' : 'stopped';
    $color_class = ($state === 'running') ? 'green-text' : 'red-text';
    $status_symbol = ($state === 'running') ? '&#9654;' : '&#9632;';
    $icon_opacity = ($state === 'running') ? 'vm-icon-started' : 'vm-icon-stopped';
  ?>
  <tr class="sortable">
    <td>
      <span class="outer">
        <span id="vm-<?=$name?>" onclick="addMicroVMContext('<?=$name?>','<?=$state?>','<?=$engine?>')" class="hand">
          <img src="<?=$icon?>" class="vm-icon <?=$icon_opacity?>" onerror="this.src='/plugins/dynamix.vm.manager/images/default.png';">
        </span>
        <span class="inner">
          <a href="#" onclick="addMicroVMContext('<?=$name?>','<?=$state?>','<?=$engine?>');return false;"><?=$name?></a><br>
          <span class="<?=$color_class?>" style="font-size:0.85rem;"><?=$status_symbol?> <?=$state?></span>
        </span>
      </span>
    </td>
    <td><?=$engine_display?></td>
    <td><?=$cpus?></td>
