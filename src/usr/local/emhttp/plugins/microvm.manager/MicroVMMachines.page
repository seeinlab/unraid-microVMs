Menu="MicroVMs:1"
Title="microVMs"
Tag="server"
Cond="is_file('/usr/local/bin/cloud-hypervisor')"
Markdown="false"
---
<?php
$plugin = "microvm.manager";
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/$plugin/include/common.php";

$cfg = microvm_load_config();
$vms = microvm_list_vms();
$vmdir = $cfg['VMDIR'] ?? '/mnt/user/appdata/microvm';
$kernel_path = "$vmdir/kernels/vmlinux";
$kernel_exists = file_exists($kernel_path);
?>

<style>
.vm-row td { padding:8px 12px; vertical-align:middle; }
.vm-state-running { color:#4CAF50; font-weight:bold; }
.vm-state-stopped { color:#f44336; }
.vm-btn { padding:4px 14px; margin:2px; cursor:pointer; border:1px solid #555; border-radius:3px; background:#333; color:#ddd; }
.vm-btn:hover { background:#555; }
.vm-btn-danger { border-color:#d32f2f; color:#f44336; }
.vm-btn-start { border-color:#4CAF50; color:#4CAF50; }
</style>

<?php if (!$kernel_exists): ?>
<div class="notice" style="margin:10px 0 15px; padding:12px;">
  <b>Kernel not found.</b> Download via terminal:<br>
  <span style="font-family:monospace;font-size:0.85em;">curl -fsSL -o <?=htmlspecialchars($kernel_path)?> https://github.com/cloud-hypervisor/linux/releases/download/ch-release-v6.2-20240908/vmlinux</span>
</div>
<?php endif; ?>

<table class="tablesorter shift ups">
<thead><tr>
  <th>Name</th>
  <th>State</th>
  <th>vCPUs</th>
  <th>Memory</th>
  <th>IP Address</th>
  <th style="width:250px;">Actions</th>
</tr></thead>
<tbody>
<?php if (empty($vms)): ?>
  <tr><td colspan="6" style="text-align:center;padding:20px;opacity:0.6;">No microVMs configured yet.</td></tr>
<?php else: ?>
  <?php foreach ($vms as $vm):
    $name = htmlspecialchars($vm['name']);
    $state = $vm['state'];
    $cpus = $vm['config']['boot_vcpus'] ?? '-';
    $mem = $vm['config']['memory_mb'] ?? '-';
    $ip = htmlspecialchars($vm['config']['ip'] ?? '-');
  ?>
  <tr class="vm-row">
    <td><img src="/plugins/microvm.manager/images/<?=($vm['config']['engine'] ?? 'cloud-hypervisor')?>.png" style="width:24px;height:24px;object-fit:contain;vertical-align:middle;margin-right:8px;"><b><?=$name?></b></td>
    <td><span class="vm-state-<?=$state?>"><?=$state?></span></td>
    <td><?=$cpus?></td>
    <td><?=$mem?> MB</td>
    <td><?=$ip?></td>
    <td>
      <?php if ($state === 'running'): ?>
        <button class="vm-btn" onclick="vmAction('stop','<?=$name?>')">Stop</button>
        <button class="vm-btn" onclick="vmResize('<?=$name?>')">Resize</button>
        <button class="vm-btn" onclick="vmAction('snapshot','<?=$name?>')">Snapshot</button>
      <?php else: ?>
        <button class="vm-btn vm-btn-start" onclick="vmAction('start','<?=$name?>')">Start</button>
      <?php endif; ?>
      <button class="vm-btn" onclick="vmInfo('<?=$name?>')">Info</button>
      <button class="vm-btn vm-btn-danger" onclick="vmDelete('<?=$name?>')">✕</button>
    </td>
  </tr>
  <?php endforeach; ?>
<?php endif; ?>
</tbody>
</table>

<br>
<input type="button" onclick="addmicroVM()" value="Add microVM" style="padding:8px 24px; font-size:14px;">

<!-- Output area -->
<div id="vmOutput" style="display:none; margin-top:15px; padding:12px; background:#111; color:#0f0; font-family:monospace; font-size:12px; max-height:200px; overflow-y:auto; border-radius:4px;"></div>

<script>
function addmicroVM() {
  location = location.pathname + '/AddMicroVM';
}

function vmAction(action, name) {
  showOutput('Running: ' + action + ' ' + name + '...');
  $.post('/plugins/<?=$plugin?>/backend/MicroVMAdmin.php', {cmd: action, name: name}, function(data) {
    var msg = (typeof data === 'object') ? JSON.stringify(data) : data;
    showOutput('Done: ' + msg);
    setTimeout(function(){ location.reload(); }, 3000);
  });
}

function vmResize(name) {
  var cpus = prompt('New CPU count:', '2');
  if (!cpus) return;
  var mem = prompt('New memory in bytes (e.g. 536870912 = 512MB):', '536870912');
  $.post('/plugins/<?=$plugin?>/backend/MicroVMAdmin.php', {cmd: 'resize', name: name, cpus: cpus, memory: mem}, function(data) {
    showOutput('Resize: ' + data);
    setTimeout(function(){ location.reload(); }, 2000);
  });
}

function vmInfo(name) {
  $.post('/plugins/<?=$plugin?>/backend/MicroVMAdmin.php', {cmd: 'info', name: name}, function(data) {
    var text;
    if (typeof data === 'object') {
      text = JSON.stringify(data, null, 2);
    } else {
      try { text = JSON.stringify(JSON.parse(data), null, 2); } catch(e) { text = data; }
    }
    swal({title: name, text: '<pre style="text-align:left;max-height:400px;overflow:auto;font-size:12px;">' + text + '</pre>', html: true});
  });
}

function vmDelete(name) {
  swal({
    title: 'Delete ' + name + '?',
    text: 'Config will be removed. Rootfs disk is preserved.',
    type: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Delete'
  }, function(confirmed) {
    if (confirmed) {
      $.post('/plugins/<?=$plugin?>/backend/MicroVMAdmin.php', {cmd: 'delete', name: name}, function(data) {
        showOutput(data);
        setTimeout(function(){ location.reload(); }, 2000);
      });
    }
  });
}

function showOutput(msg) {
  var el = document.getElementById('vmOutput');
  el.style.display = 'block';
  el.innerHTML += msg + '<br>';
  el.scrollTop = el.scrollHeight;
}
</script>
