<!-- Output area -->
<div id="vmOutput" style="display:none; margin-top:15px; padding:12px; background:#111; color:#0f0; font-family:monospace; font-size:12px; max-height:200px; overflow-y:auto; border-radius:4px;"></div>

<script>
var plugin = '<?=$plugin?>';

// Close any open context menu when clicking elsewhere
$(document).on('click', function(e) {
  if (!$(e.target).closest('.microvm-context').length) {
    $('.microvm-context').removeClass('open');
  }
});

function toggleCtx(name) {
  var el = document.getElementById('ctx-' + name);
  var isOpen = el.classList.contains('open');
  document.querySelectorAll('.microvm-context').forEach(function(m){ m.classList.remove('open'); });
  if (!isOpen) el.classList.add('open');
}

function addmicroVM() {
  location = location.pathname + '/AddMicroVM';
}

function vmAction(action, name) {
  document.querySelectorAll('.microvm-context').forEach(function(m){ m.classList.remove('open'); });
  showOutput('Running: ' + action + ' ' + name + '...');
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: action, name: name}, function(data) {
    var msg = (typeof data === 'object') ? JSON.stringify(data) : data;
    showOutput('Done: ' + msg);
    setTimeout(function(){ location.reload(); }, 3000);
  });
}

function vmResize(name, engine) {
  document.querySelectorAll('.microvm-context').forEach(function(m){ m.classList.remove('open'); });
  if (engine === 'firecracker') {
    alert('Live resize is not supported for Firecracker engine.\nRecreate the VM with new resource settings.');
    return;
  }
  var cpus = prompt('New CPU count:', '2');
  if (!cpus) return;
  var memMB = prompt('New memory (MB):', '512');
  if (!memMB) return;
  var memBytes = parseInt(memMB) * 1048576;
  showOutput('Resizing ' + name + ': ' + cpus + ' CPUs, ' + memMB + 'MB...');
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd:'resize', name:name, cpus:cpus, memory:memBytes}, function(data) {
    var msg = (typeof data === 'object') ? JSON.stringify(data) : data;
    showOutput('Result: ' + msg);
    setTimeout(function(){ location.reload(); }, 2000);
  });
}

function vmInfo(name) {
  document.querySelectorAll('.microvm-context').forEach(function(m){ m.classList.remove('open'); });
  $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'info', name: name}, function(data) {
    var text;
    if (typeof data === 'object') {
      text = JSON.stringify(data, null, 2);
    } else {
      try { text = JSON.stringify(JSON.parse(data), null, 2); } catch(e) { text = data; }
    }
    swal({title: name, text: '<pre style="text-align:left;max-height:400px;overflow:auto;font-size:12px;">' + text + '</pre>', html: true});
  });
}

function vmDelete(name) {
  document.querySelectorAll('.microvm-context').forEach(function(m){ m.classList.remove('open'); });
  swal({
    title: 'Delete ' + name + '?',
    text: 'Config will be removed. Rootfs disk is preserved.',
    type: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Delete',
    cancelButtonText: 'Cancel'
  }, function(confirmed) {
    if (confirmed) {
      $.post('/plugins/' + plugin + '/backend/MicroVMAdmin.php', {cmd: 'delete', name: name}, function(data) {
        showOutput(typeof data === 'object' ? JSON.stringify(data) : data);
        setTimeout(function(){ location.reload(); }, 2000);
      });
    }
  });
}

function startAll() {
  <?php foreach ($vms as $vm): ?>
    <?php if ($vm['state'] !== 'running'): ?>
    vmAction('start', '<?=htmlspecialchars($vm['name'])?>');
    <?php endif; ?>
  <?php endforeach; ?>
}

function stopAll() {
  <?php foreach ($vms as $vm): ?>
    <?php if ($vm['state'] === 'running'): ?>
    vmAction('stop', '<?=htmlspecialchars($vm['name'])?>');
    <?php endif; ?>
  <?php endforeach; ?>
}

function showOutput(msg) {
  var el = document.getElementById('vmOutput');
  el.style.display = 'block';
  el.innerHTML += msg + '<br>';
  el.scrollTop = el.scrollHeight;
}
</script>
