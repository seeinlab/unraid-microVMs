    $shape = ($state === 'running') ? 'play' : 'square';
    $status_class = ($state === 'running') ? 'started' : 'stopped';
    $color_class = ($state === 'running') ? 'green-text' : 'red-text';
    $status_symbol = ($state === 'running') ? '&#9654;' : '&#9632;';
    $icon_opacity = ($state === 'running') ? 'vm-icon-started' : 'vm-icon-stopped';
  ?>
  <tr class="sortable">
