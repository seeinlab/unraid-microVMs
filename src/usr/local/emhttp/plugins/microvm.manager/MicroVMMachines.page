  <?php foreach ($vms as $vm):
    $name = htmlspecialchars($vm['name']);
    $state = $vm['state'];
    $cpus = $vm['config']['boot_vcpus'] ?? '-';
    $mem_mb = $vm['config']['memory_mb'] ?? '-';
    $mem_display = ($mem_mb !== '-' && $mem_mb >= 1024) ? round($mem_mb / 1024, 1) . ' GB' : $mem_mb . ' MB';
