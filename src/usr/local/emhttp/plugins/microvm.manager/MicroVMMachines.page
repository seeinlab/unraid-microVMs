    <td style="font-family:monospace;font-size:0.85rem;"><?=htmlspecialchars($tap_display)?></td>
    <td><input class="autostart" type="checkbox" name="auto_<?=$name?>" title="Toggle autostart" data-name="<?=$name?>" <?=$autostart ? 'checked' : ''?>></td>
