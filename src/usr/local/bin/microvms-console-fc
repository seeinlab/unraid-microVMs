#!/bin/bash
# /usr/local/bin/microvms-console-fc - bidirectional serial console (CH + FC)
# Args: $1 = VM name
NAME=$1
FIFO="/tmp/microvms-${NAME}.fifo"

# Find the serial log (CH uses serial.log, FC uses .log)
if [ -f "/var/log/microvms/cloud-hypervisor/${NAME}.serial.log" ]; then
  LOG="/var/log/microvms/cloud-hypervisor/${NAME}.serial.log"
elif [ -f "/var/log/microvms/firecracker/${NAME}.log" ]; then
  LOG="/var/log/microvms/firecracker/${NAME}.log"
else
  echo "Error: No log file found for VM '$NAME'"
  exit 1
fi

if [ ! -p "$FIFO" ]; then
  echo "Error: FIFO $FIFO does not exist"
  exit 1
fi

# Tail output (start from current end, show only new output)
tail -n 0 -f "$LOG" &
TAIL_PID=$!

# Send a newline to trigger prompt display
printf '\n' > "$FIFO"

# Read stdin and write to FIFO (sends to VM serial)
while IFS= read -r line; do
  printf '%s\n' "$line" > "$FIFO"
done

kill $TAIL_PID 2>/dev/null
